<Page
    x:Class="QMSFlowDoc.Client.Views.CompetencyMatrixView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="12">
        <Grid.RowDefinitions>
             <RowDefinition Height="Auto"/>
             <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
             <TextBlock Text="Matriz de Competencias" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
             <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                <AppBarButton Icon="Refresh" Label="Recargar Matriz" Click="ReloadMatrix_Click"/>
                <AppBarButton Icon="Download" Label="Exportar CSV" Click="ExportMatrix_Click"/>
            </CommandBar>
        </StackPanel>

        <!-- Dynamic Matrix will be generated here -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
             <Grid x:Name="MatrixGrid">
                 <!-- Dynamically populated -->
             </Grid>
        </ScrollViewer>
    </Grid>
</Page>
