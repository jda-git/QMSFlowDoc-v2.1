<Page
    x:Class="QMSFlowDoc.Client.Views.StaffEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:dto="using:QMSFlowDoc.Shared.DTOs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <Button Click="Back_Click">
                <FontIcon Glyph="&#xE72B;" />
            </Button>
            <TextBlock x:Name="TitleText" Text="Alta de Personal" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <Pivot x:Name="MainPivot" Grid.Row="1">
            <!-- Tab 1: Perfil General -->
            <PivotItem Header="Perfil General">
                <ScrollViewer>
                    <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Left" Margin="0,12,0,0">
                        <TextBlock Text="Información de Usuario" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="16" RowSpacing="16">
                            <TextBox x:Name="FullNameBox" Header="Nombre Completo" PlaceholderText="Juan Pérez" Grid.Row="0" Grid.ColumnSpan="2" />
                            <TextBox x:Name="EmailBox" Header="Correo Electrónico" PlaceholderText="juan@ejemplo.com" Grid.Row="1" Grid.Column="0" />
                            <TextBox x:Name="UsernameBox" Header="Nombre de Usuario (Login)" PlaceholderText="jperez" Grid.Row="1" Grid.Column="1" />
                            <PasswordBox x:Name="PasswordBox" Header="Contraseña (Requerida solo para altas)" Grid.Row="2" Grid.Column="0" />
                        </Grid>
             
                        <TextBlock Text="Datos Profesionales" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="16" RowSpacing="16">
                            <TextBox x:Name="PositionBox" Header="Cargo / Puesto" PlaceholderText="Técnico de Laboratorio" Grid.Row="0" Grid.Column="0" />
                            <TextBox x:Name="DepartmentBox" Header="Departamento" PlaceholderText="Hematología" Grid.Row="0" Grid.Column="1" />
                            <DatePicker x:Name="HiredDatePicker" Header="Fecha de Contratación" Grid.Row="1" Grid.Column="0" />
                            <ComboBox x:Name="RoleCombo" Header="Permisos" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Administrador" Tag="Administrador" />
                                <ComboBoxItem Content="Consultor" Tag="Consultor" />
                            </ComboBox>
                            <CheckBox x:Name="IsActiveCheck" Content="Ficha Activa" IsChecked="True" Grid.Row="2" Grid.Column="0" />
                        </Grid>
             
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                            <Button x:Name="SaveButton" Content="Crear Ficha de Personal" Style="{StaticResource AccentButtonStyle}" Click="Save_Click" />
                            <Button Content="Cancelar" Click="Back_Click" />
                        </StackPanel>
                        
                        <TextBlock x:Name="ErrorText" Foreground="#E81123" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Tab 2: Formación y Educación -->
            <PivotItem Header="Formación y Educación" x:Name="TrainingTab">
                <Grid Padding="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <Button Click="AddTraining_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                <TextBlock Text="Registrar Actividad" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Historial de Capacitación" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Header Row -->
                    <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundListLowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TÍTULO DEL CURSO" FontWeight="Bold" Grid.Column="0"/>
                        <TextBlock Text="PROVEEDOR" FontWeight="Bold" Grid.Column="1"/>
                        <TextBlock Text="FECHA FINALIZACIÓN" FontWeight="Bold" Grid.Column="2"/>
                        <TextBlock Text="HORAS" FontWeight="Bold" Grid.Column="3" HorizontalAlignment="Center"/>
                        <TextBlock Text="RESULTADO" FontWeight="Bold" Grid.Column="4"/>
                        <TextBlock Text="EDITAR" FontWeight="Bold" Grid.Column="5" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView x:Name="TrainingList" Grid.Row="2" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:StaffTrainingDto">
                                <Grid Padding="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Title}" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Provider}" Grid.Column="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind CompletionDate}" Grid.Column="2"/>
                                    <TextBlock Text="{x:Bind Hours}" Grid.Column="3" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Result}" Grid.Column="4"/>
                                    <Button Grid.Column="5" Click="EditTraining_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="Editar/Eliminar" Background="Transparent" BorderThickness="0" x:Name="EditTrainingBtn">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- Tab 3: Competencias -->
            <PivotItem Header="Competencias" x:Name="CompetencyTab">
                <Grid Padding="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <Button Click="AssessCompetency_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="16"/>
                                <TextBlock Text="Evaluar Competencia" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Evaluaciones de Competencia" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Header Row -->
                    <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundListLowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="NOMBRE DE LA COMPETENCIA" FontWeight="Bold" Grid.Column="0"/>
                        <TextBlock Text="ÁREA" FontWeight="Bold" Grid.Column="1"/>
                        <TextBlock Text="FECHA EVALUACIÓN" FontWeight="Bold" Grid.Column="2"/>
                        <TextBlock Text="VALIDEZ" FontWeight="Bold" Grid.Column="3"/>
                        <TextBlock Text="RESULTADO" FontWeight="Bold" Grid.Column="4"/>
                        <TextBlock Text="EDITAR" FontWeight="Bold" Grid.Column="5" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView x:Name="CompetencyList" Grid.Row="2" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:CompetencyEvaluationDto">
                                <Grid Padding="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind CompetencyName}" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Area}" Grid.Column="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind EvaluationDate}" Grid.Column="2"/>
                                    <TextBlock Text="{x:Bind ValidUntil}" Grid.Column="3"/>
                                    <TextBlock Text="{x:Bind Outcome}" Grid.Column="4"/>
                                    <Button Grid.Column="5" Click="EditCompetency_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="Editar/Eliminar" Background="Transparent" BorderThickness="0">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
            
            <!-- Tab 4: Autorizaciones -->
            <PivotItem Header="Autorizaciones" x:Name="AuthorizationTab">
                <Grid Padding="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <Button Click="GrantAuthorization_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D7;" FontSize="16"/>
                                <TextBlock Text="Emitir Autorización" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Autorizaciones Técnicas Vigentes" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <!-- Header Row -->
                    <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundListLowBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TAREA/PROCEDIMIENTO" FontWeight="Bold" Grid.Column="0"/>
                        <TextBlock Text="DESCRIPCIÓN" FontWeight="Bold" Grid.Column="1"/>
                        <TextBlock Text="VÁLIDO DESDE" FontWeight="Bold" Grid.Column="2"/>
                        <TextBlock Text="VALIDEZ" FontWeight="Bold" Grid.Column="3"/>
                        <TextBlock Text="AUTORIZADO POR" FontWeight="Bold" Grid.Column="4"/>
                        <TextBlock Text="EDITAR" FontWeight="Bold" Grid.Column="5" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView x:Name="AuthorizationList" Grid.Row="2" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:StaffAuthorizationDto">
                                <Grid Padding="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind AuthorizationName}" Grid.Column="0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Description}" Grid.Column="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind ValidFrom}" Grid.Column="2"/>
                                    <TextBlock Text="{x:Bind ValidUntil}" Grid.Column="3"/>
                                    <TextBlock Text="{x:Bind GrantedByName}" Grid.Column="4" TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="5" Click="EditAuthorization_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="Editar/Eliminar" Background="Transparent" BorderThickness="0">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
