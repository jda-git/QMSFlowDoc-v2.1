<ContentDialog
    x:Class="QMSFlowDoc.Client.Views.Dialogs.PrintOptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Views.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="Opciones de Impresion"
    PrimaryButtonText="Imprimir"
    CloseButtonText="Cancelar"
    DefaultButton="Primary"
    MaxWidth="2000" MaxHeight="900">

    <Grid RowDefinitions="Auto, *" MinWidth="1400">
        <NavigationView x:Name="NavView" Grid.Row="0" PaneDisplayMode="Top" SelectionChanged="NavView_SelectionChanged" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" CompactModeThresholdWidth="0" ExpandedModeThresholdWidth="600">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Inventario" Tag="Inventory" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="List" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Pedido" Tag="Order">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Shop" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Consumo" Tag="Consumption">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Remove" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Entradas" Tag="Entries">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Add" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>

        <Grid Grid.Row="1" Padding="24">
            
            <!-- 1. Inventory Options -->
            <StackPanel x:Name="InventoryPanel" Spacing="16" Visibility="Visible">
                <TextBlock Text="Configuracion del Informe de Inventario" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Seleccione el criterio de ordenacion para el listado:" Foreground="Gray" />
                
                <ComboBox x:Name="SortCombo" Header="Ordenar por" MinWidth="250">
                    <ComboBoxItem Content="Nombre" IsSelected="True" />
                    <ComboBoxItem Content="Fluorescencia" />
                    <ComboBoxItem Content="Codigo Interno" />
                    <ComboBoxItem Content="Fabricante" />
                    <ComboBoxItem Content="Referencia" />
                    <ComboBoxItem Content="Stock Total" />
                </ComboBox>

                <RadioButtons x:Name="OrderRadio" Header="Sentido">
                    <RadioButton Content="Ascendente" IsChecked="True" />
                    <RadioButton Content="Descendente" />
                </RadioButtons>
            </StackPanel>

            <!-- 2. Order Options -->
            <Grid x:Name="OrderPanel" RowDefinitions="Auto, Auto, Auto, *" RowSpacing="12" Visibility="Collapsed">
                <TextBlock Text="Generar Pedido de Reposicion" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Se han anadido automaticamente los reactivos con stock bajo. Puede anadir mas manualmente." Foreground="Gray" Grid.Row="1" />
                
                <Grid Grid.Row="2" ColumnDefinitions="Auto, *" ColumnSpacing="12">
                     <Button Click="AddToOrder_Click" Grid.Column="0" VerticalAlignment="Top" ToolTipService.ToolTip="Anadir a la lista" Style="{StaticResource AccentButtonStyle}">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                             <SymbolIcon Symbol="Add" />
                             <TextBlock Text="AÑADIR" />
                         </StackPanel>
                     </Button>
                     <AutoSuggestBox x:Name="OrderSearchBox" PlaceholderText="Buscar reactivo para anadir..." QueryIcon="Find" 
                                    TextChanged="OrderSearchBox_TextChanged" 
                                    SuggestionChosen="OrderSearchBox_SuggestionChosen"
                                    TextMemberPath="Name"
                                    Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Stretch" />
                </Grid>

                <ListView x:Name="OrderList" Grid.Row="3" MaxHeight="450" MaxWidth="1200" HorizontalAlignment="Left" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" CornerRadius="4" ScrollViewer.HorizontalScrollMode="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Reactivo" FontWeight="Bold" />
                                <TextBlock Text="Fluor." Grid.Column="1" FontWeight="Bold" />
                                <TextBlock Text="Cod. Int." Grid.Column="2" FontWeight="Bold" />
                                <TextBlock Text="Fabricante" Grid.Column="3" FontWeight="Bold" />
                                <TextBlock Text="Ref." Grid.Column="4" FontWeight="Bold" />
                                <TextBlock Text="Stock" Grid.Column="5" FontWeight="Bold" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Fluorescence}" Grid.Column="1" Foreground="Gray" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding InternalCode}" Grid.Column="2" Foreground="Gray" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Manufacturer}" Grid.Column="3" Foreground="Gray" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Reference}" Grid.Column="4" Foreground="Gray" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CurrentStock}" Grid.Column="5" HorizontalAlignment="Right" Padding="0,0,12,0" Foreground="Red" VerticalAlignment="Center" />
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Click="RemoveFromOrder_Click" Tag="{Binding}" Grid.Column="6" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            
            <!-- 3. Consumption Options -->
            <StackPanel x:Name="ConsumptionPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Text="Informe de Consumo" Style="{StaticResource SubtitleTextBlockStyle}" />
                
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <CalendarDatePicker x:Name="ConsumStart" Header="Fecha Inicio" DateFormat="{}{day.integer}/{month.integer}/{year.full}" Width="200" />
                    <CalendarDatePicker x:Name="ConsumEnd" Header="Fecha Fin" DateFormat="{}{day.integer}/{month.integer}/{year.full}" Width="200" />
                </StackPanel>
                
                <RadioButtons x:Name="ConsumScopeRadio" Header="Alcance" SelectionChanged="ConsumScope_Changed">
                    <RadioButton Content="Todos los Reactivos" Tag="All" IsChecked="True" />
                    <RadioButton Content="Reactivo Especifico" Tag="Single" />
                </RadioButtons>
                
                <AutoSuggestBox x:Name="ConsumSearchBox" Header="Buscar Reactivo" PlaceholderText="Escriba nombre..." 
                                TextChanged="ReportSearchBox_TextChanged"
                                SuggestionChosen="ReportSearchBox_SuggestionChosen"
                                TextMemberPath="Name"
                                Visibility="Collapsed" Width="450" HorizontalAlignment="Left" />
                
                <TextBlock x:Name="ConsumSelectedText" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" Visibility="Collapsed" />
            </StackPanel>

            <!-- 4. Entries Options -->
            <StackPanel x:Name="EntriesPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Text="Informe de Entradas" Style="{StaticResource SubtitleTextBlockStyle}" />
                
                 <StackPanel Orientation="Horizontal" Spacing="20">
                    <CalendarDatePicker x:Name="EntryStart" Header="Fecha Inicio" DateFormat="{}{day.integer}/{month.integer}/{year.full}" Width="200" />
                    <CalendarDatePicker x:Name="EntryEnd" Header="Fecha Fin" DateFormat="{}{day.integer}/{month.integer}/{year.full}" Width="200" />
                </StackPanel>
                
                <RadioButtons x:Name="EntryScopeRadio" Header="Alcance" SelectionChanged="EntryScope_Changed">
                    <RadioButton Content="Todos los Reactivos" Tag="All" IsChecked="True" />
                    <RadioButton Content="Reactivo Especifico" Tag="Single" />
                </RadioButtons>
                
                <AutoSuggestBox x:Name="EntrySearchBox" Header="Buscar Reactivo" PlaceholderText="Escriba nombre..." 
                                TextChanged="ReportSearchBox_TextChanged"
                                SuggestionChosen="ReportSearchBox_SuggestionChosen"
                                TextMemberPath="Name"
                                Visibility="Collapsed" Width="450" HorizontalAlignment="Left" />

                 <TextBlock x:Name="EntrySelectedText" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" Visibility="Collapsed" />
            </StackPanel>

        </Grid>
    </Grid>
</ContentDialog>
