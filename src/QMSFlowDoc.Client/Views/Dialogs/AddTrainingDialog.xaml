<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="QMSFlowDoc.Client.Views.Dialogs.AddTrainingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Registrar Formación"
    PrimaryButtonText="Registrar"
    CloseButtonText="Cancelar"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="450">
        <TextBlock Text="Introduzca los datos de la formación completada." TextWrapping="Wrap"/>
        
        <!-- Selección de Personal (Global Mode) -->
        <ComboBox x:Name="StaffCombo" 
                  Header="Personal"
                  PlaceholderText="Seleccione empleado"
                  HorizontalAlignment="Stretch"
                  Visibility="Collapsed"
                  DisplayMemberPath="FullName"
                  SelectedValuePath="Id"/>

        <!-- Selección de Competencia (Opcional) -->
        <ComboBox x:Name="CompetencyCombo"
                  Header="Competencia Relacionada (Opcional)"
                  PlaceholderText="Seleccione competencia..."
                  HorizontalAlignment="Stretch"
                  DisplayMemberPath="Name"
                  SelectedValuePath="Id"
                  SelectionChanged="CompetencyCombo_SelectionChanged"/>

        <!-- Título del curso - TEXTO LIBRE -->
        <TextBox x:Name="TitleBox" 
                 Header="Título del Curso / Actividad"
                 PlaceholderText="Ej: Curso de Bioseguridad en el Laboratorio"
                 HorizontalAlignment="Stretch"/>
        
        <!-- Proveedor -->
        <TextBox x:Name="ProviderBox" 
                 Header="Proveedor / Organizador"
                 PlaceholderText="Ej: AENOR, Universidad, Interno"
                 HorizontalAlignment="Stretch"/>
        
        <!-- Fechas en Grid con columnas asignadas -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CalendarDatePicker x:Name="CompletionDatePicker"
                               Grid.Column="0"
                               Header="Fecha de Finalización"
                               PlaceholderText="Seleccione fecha"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,6,0"/>
            <TextBox x:Name="HoursBox"
                     Grid.Column="1"
                     Header="Horas"
                     PlaceholderText="Ej: 20"
                     HorizontalAlignment="Stretch"
                     Margin="6,0,0,0"/>
        </Grid>
        
        <!-- Certificado -->
        <StackPanel Spacing="8">
            <TextBlock Text="Certificado / Evidencia (Opcional)" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="UploadButton" Click="UploadButton_Click">
                    <Button.Content>
                         <StackPanel Orientation="Horizontal" Spacing="8">
                             <FontIcon Glyph="&#xE898;"/>
                             <TextBlock Text="Seleccionar Archivo"/>
                         </StackPanel>
                    </Button.Content>
                </Button>
                <TextBlock x:Name="FileNameText" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="250"
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
        </StackPanel>
        
        <ComboBox x:Name="ResultCombo"
                  Header="Resultado"
                  HorizontalAlignment="Stretch"
                  SelectedIndex="0">
            <ComboBoxItem Content="APTO" Tag="APTO"/>
            <ComboBoxItem Content="NO APTO" Tag="NO_APTO"/>
        </ComboBox>
        
        <TextBox x:Name="NotesBox"
                 Header="Notas (Opcional)"
                 PlaceholderText="Observaciones adicionales"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Height="80"/>
    </StackPanel>
</ContentDialog>
