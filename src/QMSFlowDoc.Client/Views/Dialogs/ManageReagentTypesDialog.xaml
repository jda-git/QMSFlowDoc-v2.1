<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="QMSFlowDoc.Client.Views.Dialogs.ManageReagentTypesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:QMSFlowDoc.Shared.Models"
    mc:Ignorable="d"
    Title="Gestionar Tipos de Reactivos"
    CloseButtonText="Cerrar"
    DefaultButton="Close">

    <StackPanel Spacing="16" MinWidth="400">
        <TextBlock Text="Defina los tipos de reactivos disponibles en el sistema." Foreground="Gray" />

        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
            <TextBox x:Name="NewTypeBox" PlaceholderText="Nombre del nuevo tipo" />
            <Button x:Name="AddButton" Content="Agregar" Click="AddReagentType_Click" Grid.Column="1" />
        </Grid>

        <ListView x:Name="ReagentTypesList" BorderThickness="1" BorderBrush="#E0E0E0" CornerRadius="4" Height="250">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ReagentType">
                    <Grid Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                Click="DeleteType_Click" CommandParameter="{x:Bind Id}" 
                                Style="{StaticResource TextBlockButtonStyle}" Foreground="Red" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
