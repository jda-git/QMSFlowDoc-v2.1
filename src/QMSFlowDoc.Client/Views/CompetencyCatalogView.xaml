<Page
    x:Class="QMSFlowDoc.Client.Views.CompetencyCatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:dto="using:QMSFlowDoc.Shared.DTOs"
    xmlns:models="using:QMSFlowDoc.Shared.Models"
    xmlns:converters="using:QMSFlowDoc.Client.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="12" Spacing="8">
                <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                    <AppBarButton Icon="Add" Label="Nueva Competencia" Click="AddCompetency_Click" />
                    <AppBarButton Icon="Refresh" Label="Actualizar" Click="RefreshList_Click" />
                </CommandBar>
                <TextBox x:Name="SearchBox" PlaceholderText="Buscar..." TextChanged="SearchBox_TextChanged" />
            </StackPanel>

            <ListView x:Name="CompetencyList" 
                      Grid.Row="1" 
                      SelectionChanged="CompetencyList_SelectionChanged"
                      Padding="0,0,0,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Competency">
                        <Grid Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Bind Code}" FontWeight="Bold" />
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Category}" FontSize="12" Foreground="Gray" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right: Detail -->
        <Grid Grid.Column="1" x:Name="DetailPane" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="DetailCode" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="DetailName" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="DetailDescription" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Border Background="LightGray" CornerRadius="4" Padding="6,2">
                            <TextBlock x:Name="DetailCategory" FontSize="12" Foreground="Black" />
                        </Border>
                        <TextBlock x:Name="DetailFrequency" Foreground="Gray" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Click="EditCompetency_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE70F;" FontSize="16" />
                            <TextBlock Text="Editar" />
                        </StackPanel>
                    </Button>
                    <Button Click="DeleteCompetency_Click" Foreground="Red">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                            <TextBlock Text="Eliminar" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content (Evaluated Staff?) -->
            <Grid Grid.Row="1" Padding="24">
                <TextBlock Text="Selecciona una competencia para ver detalles." 
                           Visibility="Collapsed" x:Name="PlaceholderText"/>
            </Grid>
        </Grid>
        
         <StackPanel Grid.Column="1" x:Name="EmptySelectionPane" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE82D;" FontSize="48" Foreground="Gray" />
            <TextBlock Text="Selecciona una competencia para ver detalles" Foreground="Gray" FontSize="16" />
        </StackPanel>
    </Grid>
</Page>
