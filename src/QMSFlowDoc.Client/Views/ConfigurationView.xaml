<Page
    x:Class="QMSFlowDoc.Client.Views.ConfigurationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:models="using:QMSFlowDoc.Shared.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="32" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Configuración del Sistema" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Security & Permissions -->
            <StackPanel x:Name="SecurityPanel" Spacing="12" Visibility="Collapsed">
                <TextBlock Text="Seguridad y Accesos" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Gestione los roles y permisos de los usuarios." Foreground="Gray" />
                <Button Content="Configurar Matriz de Permisos" Click="ManagePermissions_Click" />
            </StackPanel>

            <!-- Network Storage Configuration -->
            <StackPanel Spacing="12">
                <TextBlock Text="Repositorio de Red" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Configure las rutas de almacenamiento para sincronización." Foreground="Gray" />
                
                <!-- Network Path -->
                <TextBox x:Name="NetworkPathBox" Header="Ruta de Red (UNC)" 
                         PlaceholderText="Ej: \\SERVIDOR\QMSFlowDoc\QMS" />
                <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap">
                    Ruta UNC a la carpeta compartida de red que actuará como repositorio principal.
                    Ejemplo: \\192.168.1.100\QMSFlowDoc\QMS o \\fileserver\shared\QMS
                </TextBlock>
                
                <!-- Local Path -->
                <TextBox x:Name="LocalPathBox" Header="Ruta Local (Workspace)" 
                         PlaceholderText="Ej: C:\ProgramData\QMSFlowDoc\QMS" />
                <TextBlock FontSize="12" Foreground="Gray" TextWrapping="Wrap">
                    Carpeta local donde se almacenará una copia de trabajo para acceso rápido.
                </TextBlock>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Probar Conexión" Click="TestConnection_Click" />
                    <Button Content="Inicializar Estructura" Click="InitializeStructure_Click" />
                    <Button Content="Guardar Configuración" Click="SaveNetworkSettings_Click" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
                
                <!-- Advanced Options -->
                <Expander Header="Opciones Avanzadas" Margin="0,12,0,0">
                    <StackPanel Spacing="12" Padding="12">
                        <CheckBox x:Name="AutoSyncCheckBox" Content="Sincronizar automáticamente al iniciar" IsChecked="True" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Intervalo de sincronización (minutos)" />
                            <Slider x:Name="SyncIntervalSlider" Minimum="1" Maximum="60" Value="5" 
                                    StepFrequency="1" TickFrequency="5" TickPlacement="BottomRight" />
                            <TextBlock Text="{x:Bind SyncIntervalSlider.Value, Mode=OneWay}" 
                                       FontSize="12" Foreground="Gray" HorizontalAlignment="Right" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Tiempo de inactividad para cierre de sesión (minutos)" />
                            <Slider x:Name="InactivitySlider" Minimum="5" Maximum="60" Value="30" 
                                    StepFrequency="5" TickFrequency="5" TickPlacement="BottomRight" />
                            <TextBlock Text="{x:Bind InactivitySlider.Value, Mode=OneWay}" 
                                       FontSize="12" Foreground="Gray" HorizontalAlignment="Right" />
                        </StackPanel>
                        
                        <Button Content="Forzar Sincronización Completa" Click="ForceSync_Click" />
                        <Button Content="Ver Log de Sincronización" Click="ViewSyncLog_Click" />
                        <Button Content="Exportar Logs de Auditoría (PDF)" Click="ExportAuditLog_Click" />
                    </StackPanel>

                </Expander>
            </StackPanel>
            
            <TextBlock x:Name="StatusText" Foreground="Green" />
        </StackPanel>
    </ScrollViewer>
</Page>
