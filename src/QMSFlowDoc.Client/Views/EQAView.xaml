<Page
    x:Class="QMSFlowDoc.Client.Views.EQAView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:dto="using:QMSFlowDoc.Shared.DTOs"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <UserControl.Resources>
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Program List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="12" Spacing="8">
                <TextBlock Text="Control Externo (EQA)" Style="{StaticResource SubtitleTextBlockStyle}" />
                <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                    <AppBarButton Icon="Add" Label="Nuevo Programa" Click="AddProgram_Click" />
                </CommandBar>
            </StackPanel>

            <ListView x:Name="ProgramList" 
                      Grid.Row="1" 
                      SelectionChanged="ProgramList_SelectionChanged"
                      Padding="0,0,0,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="dto:EQAProgramDto">
                        <Grid Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Provider}" FontSize="12" Foreground="Gray" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind LastResult}" FontSize="12" Foreground="{x:Bind LastResultColor}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- Badge for pending -->
                                <Border Background="Orange" CornerRadius="10" Padding="8,2" Visibility="{x:Bind PendingCount, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind PendingCount}" Foreground="White" FontSize="11" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right Pane: Details -->
        <Grid Grid.Column="1" x:Name="DetailPane" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="DetailTitle" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="DetailProvider" Style="{StaticResource BodyTextBlockStyle}" Foreground="Gray" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Click="EditProgram_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE70F;" FontSize="16" />
                            <TextBlock Text="Editar" />
                        </StackPanel>
                    </Button>
                    <Button Click="DeleteProgram_Click" Foreground="Red">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                            <TextBlock Text="Eliminar" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Results List -->
            <Grid Grid.Row="1" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
                    <TextBlock Text="Historial de Resultados" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    <Button Style="{StaticResource AccentButtonStyle}" Click="AddResult_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="16" />
                            <TextBlock Text="Registrar Resultado" />
                        </StackPanel>
                    </Button>
                    <Button Click="ExportPdf_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEA90;" FontSize="16" />
                            <TextBlock Text="Exportar PDF" />
                        </StackPanel>
                    </Button>
                </StackPanel>


                <!-- Header for List -->
                <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Ciclo" Grid.Column="0" FontWeight="Bold"/>
                    <TextBlock Text="Estado" Grid.Column="1" FontWeight="Bold"/>
                    <TextBlock Text="Desempeño" Grid.Column="2" FontWeight="Bold"/>
                    <TextBlock Text="Puntos" Grid.Column="3" FontWeight="Bold"/>
                    <TextBlock Text="Enviado" Grid.Column="4" FontWeight="Bold"/>
                    <TextBlock Text="Notas" Grid.Column="5" FontWeight="Bold"/>
                </Grid>

                <ListView x:Name="ResultsList" Grid.Row="2" SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:EQAResultDto">
                            <Grid Padding="12,8" Background="Transparent">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Evaluar Desempeño" Click="EvaluateResult_Click" Icon="Edit" Tag="{x:Bind}"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind CycleIdentifier}" Grid.Column="0" />
                                <TextBlock Text="{x:Bind Status}" Grid.Column="1" />
                                <TextBlock Text="{x:Bind Performance}" Grid.Column="2" Foreground="{x:Bind PerformanceColor}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Score.ToString()}" Grid.Column="3" />
                                <TextBlock Text="{x:Bind local:EQAView.FormatDate(SubmissionDate)}" Grid.Column="4" />
                                <TextBlock Text="{x:Bind Notes}" Grid.Column="5" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Notes}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <TextBlock x:Name="EmptyResultsText" Grid.Row="2" Text="No hay resultados registrados." 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <StackPanel Grid.Column="1" x:Name="EmptySelectionPane" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE7F4;" FontSize="48" Foreground="Gray" />
            <TextBlock Text="Selecciona un programa para ver detalles" Foreground="Gray" FontSize="16" />
        </StackPanel>
    </Grid>
</Page>
