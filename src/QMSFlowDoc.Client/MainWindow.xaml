<Window
    x:Class="QMSFlowDoc.Client.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="QMS FlowDoc">

    <Grid>
        <NavigationView x:Name="RootNavigationView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="True"
                        Visibility="Collapsed">
            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox x:Name="GlobalSearchBox"
                                PlaceholderText="Búsqueda global..."
                                QueryIcon="Find"
                                TextChanged="GlobalSearchBox_TextChanged"
                                SuggestionChosen="GlobalSearchBox_SuggestionChosen" />
            </NavigationView.AutoSuggestBox>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Icon="Home" Tag="dashboard" />
                <NavigationViewItem Content="Documentos" Icon="Document" Tag="documents" />
                <NavigationViewItem Content="Inventario" Icon="Library" Tag="inventory" />
                <NavigationViewItem Content="Equipos" Icon="Setting" Tag="equipment" />
                <NavigationViewItem Content="Personal" Icon="Contact" Tag="personal" />
                <NavigationViewItem Content="Control de Calidad (EQA)" Icon="World" Tag="eqa" />
                <NavigationViewItem Content="Métodos" Icon="Library" Tag="methods" />
                <NavigationViewItem Content="Mejoras" Icon="Highlight" Tag="improvement" />
                <NavigationViewItem Content="Auditoría" Icon="List" Tag="audit" />

                <NavigationViewItem Content="Incidencias" Icon="ReportHacked" Tag="issues" />
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel>
                    <StackPanel Spacing="8" Padding="12">
                        <!-- Sync Status Indicator -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <!-- Network Status Icon -->
                                <FontIcon x:Name="NetworkStatusIcon" 
                                          Glyph="&#xE774;" 
                                          FontSize="14" 
                                          Foreground="Green"
                                          ToolTipService.ToolTip="Estado de red" />
                                
                                <!-- Sync Status Text -->
                                <TextBlock x:Name="SyncStatusText" 
                                           Text="Sincronizado" 
                                           FontSize="11" 
                                           VerticalAlignment="Center"
                                           Foreground="Gray" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <!-- Pending Operations Badge -->
                                <Button x:Name="PendingOpsButton" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        Padding="6,4"
                                        Click="PendingOps_Click"
                                        ToolTipService.ToolTip="Operaciones pendientes"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE81C;" FontSize="12" Foreground="Orange" />
                                        <TextBlock x:Name="PendingOpsCount" 
                                                   Text="0" 
                                                   FontSize="11" 
                                                   FontWeight="SemiBold"
                                                   Foreground="Orange" />
                                    </StackPanel>
                                </Button>
                                
                                <!-- Conflicts Badge -->
                                <Button x:Name="ConflictsButton" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        Padding="6,4"
                                        Click="Conflicts_Click"
                                        ToolTipService.ToolTip="Conflictos detectados"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="Red" />
                                        <TextBlock x:Name="ConflictsCount" 
                                                   Text="0" 
                                                   FontSize="11" 
                                                   FontWeight="SemiBold"
                                                   Foreground="Red" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Last Sync Time -->
                        <TextBlock x:Name="LastSyncTimeText" 
                                   Text="Última sincronización: Nunca" 
                                   FontSize="10" 
                                   Foreground="Gray"
                                   Margin="0,0,0,4" />
                        
                        <!-- Manual Sync Button -->
                        <Button x:Name="SyncButton" 
                                Click="SyncButton_Click" 
                                HorizontalAlignment="Stretch"
                                ToolTipService.ToolTip="Sincronizar manualmente">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon x:Name="SyncIcon" Glyph="&#xE895;" FontSize="14" />
                                <TextBlock Text="Sincronizar" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    
                    <NavigationViewItemSeparator />
                    
                    <NavigationViewItem Content="Cambiar Contraseña" Icon="Permissions" Tapped="ChangePassword_Tapped" />
                    <NavigationViewItem Content="Cerrar Sesión" Icon="Cancel" Tapped="Logout_Tapped" Foreground="Red" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Frame x:Name="RootFrame" Visibility="Visible" />
    </Grid>
</Window>
