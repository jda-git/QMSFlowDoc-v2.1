@page "/inventory"
@rendermode InteractiveServer
@using QMSFlowDoc.Application.Services.Inventory
@using QMSFlowDoc.Domain.Entities
@using QMSFlowDoc.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IInventoryService InventoryService
@inject IJSRuntime JS

<PageTitle>Control de Inventario y Reactivos - QMSFlowDoc</PageTitle>

<div class="inventory-container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1"><i class="bi bi-box-seam text-success me-2"></i>Inventario y Reactivos</h1>
            <p class="text-muted mb-0">Control de trazabilidad de reactivos, lotes y vigencia (Requisitos ISO 15189)</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary px-3" @onclick="OpenMovementsModal">
                <i class="bi bi-journal-text me-2"></i> Historial de Movimientos
            </button>
            <button class="btn btn-premium px-4" @onclick="OpenAddReagentModal">
                <i class="bi bi-plus-circle me-2"></i> Nuevo Reactivo
            </button>
        </div>
    </div>

    <!-- Reagents Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Reactivos Registrados</span>
                        <h3 class="fw-bold mb-0">@reagentsList.Count</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded p-2.5">
                        <i class="bi bi-boxes fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Stock Crítico (Bajo Mínimo)</span>
                        <h3 class="fw-bold mb-0 text-warning">@lowStockCount</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning rounded p-2.5">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Lotes Caducados o Próximos</span>
                        <h3 class="fw-bold mb-0 text-danger">@expiredOrNearExpiryCount</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 text-danger rounded p-2.5">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white border">
        <!-- Search & Filters -->
        <div class="row g-3 align-items-center mb-4">
            <div class="col-md-6 col-lg-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control form-control-premium border-start-0 ps-1" 
                           placeholder="Buscar reactivo por nombre, código o fabricante..." 
                           @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <select class="form-select form-select-premium" @bind="stockFilter">
                    <option value="all">Todos los Reactivos</option>
                    <option value="active">Activos únicamente</option>
                    <option value="low">Stock bajo el mínimo</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-4 text-end">
                <span class="text-muted small">@FilteredReagents.Count() reactivos encontrados</span>
            </div>
        </div>

        <!-- Reagents Table -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light border-bottom text-muted small text-uppercase">
                    <tr>
                        <th class="ps-3 cursor-pointer" @onclick='() => SortTable("code")'>Código <i class="bi @GetSortIcon("code") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("name")'>Nombre <i class="bi @GetSortIcon("name") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("fluorescence")'>Fluorescencia / Marca <i class="bi @GetSortIcon("fluorescence") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("type")'>Tipo / Clasificación <i class="bi @GetSortIcon("type") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("supplier")'>Proveedor <i class="bi @GetSortIcon("supplier") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("stock")'>Stock Actual <i class="bi @GetSortIcon("stock") small"></i></th>
                        <th class="cursor-pointer" @onclick='() => SortTable("expiry")'>Próxima Caducidad <i class="bi @GetSortIcon("expiry") small"></i></th>
                        <th class="text-end pe-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <div class="spinner-border text-success spinner-border-sm me-2" role="status"></div>
                                <span class="text-muted">Cargando inventario...</span>
                            </td>
                        </tr>
                    }
                    else if (!FilteredReagents.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-box-fill h2 d-block mb-2"></i> No se encontraron reactivos.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var reagent in FilteredReagents)
                        {
                            var isLow = reagent.TotalStock <= reagent.MinStock;
                            <tr class="reagent-tr @(selectedReagent?.Id == reagent.Id ? "table-active" : "") cursor-pointer" @onclick="() => SelectReagent(reagent.Id)">
                                <td class="ps-3 fw-bold text-secondary">@(reagent.InternalCode ?? "N/A")</td>
                                <td>
                                    <div class="fw-semibold text-dark">@reagent.Name</div>
                                    @if (!string.IsNullOrEmpty(reagent.Reference))
                                    {
                                        <small class="text-muted font-monospace">Ref: @reagent.Reference</small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(reagent.Fluorescence))
                                    {
                                        <span class="badge bg-info bg-opacity-10 text-info fw-bold me-1">@reagent.Fluorescence</span>
                                    }
                                    <span class="text-muted small">@reagent.Manufacturer</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-secondary border">@reagent.ReagentType</span>
                                    @if (!string.IsNullOrEmpty(reagent.Classification))
                                    {
                                        <span class="badge bg-light text-primary border">@reagent.Classification</span>
                                    }
                                </td>
                                <td class="small text-secondary">@(reagent.SupplierName ?? "Sin proveedor")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="fw-bold @(isLow ? "text-danger" : "text-success")">
                                            @reagent.TotalStock.ToString("N0")
                                        </span>
                                        <span class="text-muted small ms-1">/ @reagent.MinStock.ToString("N0") mín</span>
                                        @if (isLow)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill ms-2 small-badge">Stock Bajo</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (reagent.NearestExpiry.HasValue)
                                    {
                                        <span class="badge @GetExpiryBadgeClass(reagent.ExpiryStatus)">
                                            <i class="bi bi-calendar-event me-1"></i>
                                            @reagent.NearestExpiry.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td class="text-end pe-3" @onclick:stopPropagation="true">
                                    <div class="btn-group shadow-sm border rounded bg-white">
                                        <button class="btn btn-white btn-sm px-2.5" @onclick="() => OpenRegisterLotModal(reagent)" title="Registrar Lote">
                                            <i class="bi bi-plus-square text-success"></i>
                                        </button>
                                        <button class="btn btn-white btn-sm px-2.5" @onclick="() => OpenAdjustStockModal(reagent, null)" title="Ajuste Stock">
                                            <i class="bi bi-sliders text-secondary"></i>
                                        </button>
                                        <button class="btn btn-white btn-sm px-2.5 text-primary" @onclick="() => OpenEditReagentModal(reagent)" title="Editar Reactivo">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-white btn-sm px-2.5 text-danger" @onclick="() => ConfirmDeleteReagent(reagent)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Reagent Detail Bottom Drawer / Side Drawer -->
    @if (selectedReagent != null)
    {
        <div class="card border-0 shadow-lg rounded-4 p-4 bg-white mt-4 border border-success border-opacity-25 animate-slide-up">
            <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-3">
                <div>
                    <div class="d-flex align-items-center mb-1">
                        <span class="badge bg-success me-2">@(selectedReagent.InternalCode ?? "S/C")</span>
                        @if (!string.IsNullOrEmpty(selectedReagent.Fluorescence))
                        {
                            <span class="badge bg-info text-white me-2">@selectedReagent.Fluorescence</span>
                        }
                        <h4 class="fw-bold text-dark mb-0 d-inline-block">@selectedReagent.Name</h4>
                        <span class="badge bg-light text-secondary border ms-3">@selectedReagent.Status</span>
                    </div>
                    <div class="text-muted small">
                        Fabricante: <strong>@(selectedReagent.Manufacturer ?? "N/A")</strong> &bull;
                        Referencia: <strong>@(selectedReagent.Reference ?? "N/A")</strong> &bull;
                        Tipo: <strong>@(selectedReagent.ReagentType)</strong> &bull;
                        Clasificación ISO: <strong>@(selectedReagent.Classification ?? "General")</strong>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-success btn-sm fw-bold px-3 py-2" @onclick="() => OpenRegisterLotModal(null)">
                        <i class="bi bi-plus-square me-1"></i> Registrar Lote
                    </button>
                    <button class="btn btn-outline-success btn-sm fw-bold px-3 py-2" @onclick="() => OpenAdjustStockModal(null, null)">
                        <i class="bi bi-sliders me-1"></i> Ajustar Stock
                    </button>
                    <button class="btn btn-light btn-sm rounded-circle" @onclick="() => selectedReagent = null"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="row g-4">
                <!-- Metadata Info -->
                <div class="col-md-4">
                    <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-info-circle me-2"></i>Almacenamiento y Control</h6>
                    <div class="bg-light p-3 rounded-3 border">
                        <div class="mb-2.5">
                            <span class="text-muted d-block small">Condiciones de Almacenamiento</span>
                            <span class="fw-medium text-dark"><i class="bi bi-thermometer-half text-danger me-1"></i>@(selectedReagent.StorageConditions ?? "Temperatura Ambiente")</span>
                        </div>
                        <div class="mb-2.5">
                            <span class="text-muted d-block small">Ubicación por Defecto</span>
                            <span class="fw-medium text-dark"><i class="bi bi-geo-alt-fill text-primary me-1"></i>@(selectedReagent.DefaultLocation?.Name ?? "No asignada")</span>
                        </div>
                        <div class="mb-2.5">
                            <span class="text-muted d-block small">Vida Útil Abierto</span>
                            <span class="fw-medium text-dark"><i class="bi bi-calendar2-range text-secondary me-1"></i>@(selectedReagent.OpenShelfLifeDays.HasValue ? $"{selectedReagent.OpenShelfLifeDays.Value} días" : "Sin restringir")</span>
                        </div>
                        <div class="mb-0">
                            <span class="text-muted d-block small">Stock Objetivo / Reorden</span>
                            <span class="fw-medium text-dark"><i class="bi bi-hash text-success me-1"></i>@selectedReagent.TargetStock.ToString("N0") / @selectedReagent.ReorderQty.ToString("N0") uds.</span>
                        </div>
                    </div>
                </div>

                <!-- Lots Table -->
                <div class="col-md-8">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-secondary mb-0"><i class="bi bi-diagram-3 me-2"></i>Lotes Registrados y Disponibilidad</h6>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="showAllLotsSwitch" @bind="showAllLots" />
                            <label class="form-check-label text-muted small" for="showAllLotsSwitch">Ver lotes vacíos/consumidos</label>
                        </div>
                    </div>
                    <div class="table-responsive border rounded-3 bg-white">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="bg-light border-bottom text-muted text-uppercase">
                                <tr>
                                    <th class="ps-3">Lote</th>
                                    <th>F. Recepción</th>
                                    <th>F. Caducidad</th>
                                    <th>Ubicación</th>
                                    <th>Estado</th>
                                    <th>Disponible</th>
                                    <th class="text-end pe-3">Acciones de Consumo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var displayedLots = showAllLots
                                        ? selectedReagent.Lots
                                        : selectedReagent.Lots.Where(l => l.AvailableQty > 0 && l.Status != LotStatus.CONSUMED).ToList();
                                }
                                @if (displayedLots == null || !displayedLots.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            No hay lotes con stock disponibles. active el interruptor para ver el historial completo.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var lot in displayedLots)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold text-dark">@lot.LotNumber</td>
                                            <td>@lot.ReceivedDate.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="fw-medium @(lot.ExpiryDate < DateTime.UtcNow ? "text-danger fw-bold" : "")">
                                                    @lot.ExpiryDate.ToString("dd/MM/yyyy")
                                                </span>
                                            </td>
                                            <td class="text-muted">@(lot.Location?.Name ?? "Por defecto")</td>
                                            <td>
                                                <select class="form-select form-select-sm status-dropdown-select @GetLotStatusColorClass(lot.Status)"
                                                        value="@lot.Status.ToString()" 
                                                        @onchange="(e) => UpdateLotStatus(lot, e.Value?.ToString())">
                                                    <option value="RELEASED">Liberado</option>
                                                    <option value="QUARANTINE">Cuarentena</option>
                                                    <option value="IN_USE">En uso</option>
                                                    <option value="CONSUMED">Consumido</option>
                                                    <option value="BLOCKED">Bloqueado</option>
                                                    <option value="EXPIRED">Caducado</option>
                                                    <option value="RECALLED">Retirado</option>
                                                </select>
                                            </td>
                                            <td class="fw-bold">@lot.AvailableQty.ToString("N2") <small class="text-muted">/ @lot.ReceivedQty.ToString("N0")</small></td>
                                            <td class="text-end pe-3">
                                                <div class="d-flex justify-content-end gap-1">
                                                    @if (lot.AvailableQty > 0 && (lot.Status == LotStatus.RELEASED || lot.Status == LotStatus.IN_USE))
                                                    {
                                                        <button class="btn btn-outline-success btn-xs px-2 py-0.5" @onclick="() => QuickConsumeLot(lot, 1)" title="Consumir 1 unidad">
                                                            -1 ud
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-xs px-2 py-0.5" @onclick="() => QuickConsumeLot(lot, lot.AvailableQty)" title="Marcar como consumido">
                                                            Consumir Todo
                                                        </button>
                                                    }
                                                    <button class="btn btn-light btn-xs p-1" @onclick="() => OpenAdjustStockModal(null, lot)" title="Ajuste Personalizado">
                                                        <i class="bi bi-sliders"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal: Registrar / Editar Reactivo -->
@if (showReagentModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content card shadow border-0 rounded-4 w-100">
                <div class="card-header bg-success text-white py-3 border-0 rounded-top-4 d-flex justify-content-between">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-box-seam me-2"></i>
                        @(isEditingReagent ? "Editar Reactivo" : "Registrar Nuevo Reactivo")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showReagentModal = false"></button>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="reagentModel" OnValidSubmit="SaveReagent">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Nombre del Reactivo *</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.Name" placeholder="Ej. CD3 PE-Cy7 o Tampón de Lisis" />
                                <ValidationMessage For="() => reagentModel.Name" class="text-danger small" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium text-secondary">Código Interno</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.InternalCode" placeholder="Ej. R-042" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium text-secondary">Fluorescencia</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.Fluorescence" placeholder="Ej. PE-Cy7, FITC" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Fabricante / Marca</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.Manufacturer" placeholder="Ej. BD Biosciences" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Referencia / Catálogo</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.Reference" placeholder="Ej. 557851" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Tipo de Reacción / Uso *</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.ReagentType" placeholder="Ej. Anticuerpo, Tampón, Calibrador" />
                                <ValidationMessage For="() => reagentModel.ReagentType" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Clasificación ISO 15189</label>
                                <select class="form-select form-select-premium" @bind="reagentModel.Classification">
                                    <option value="Anticuerpo Monoclonal">Anticuerpo Monoclonal</option>
                                    <option value="Fluorocromo">Fluorocromo</option>
                                    <option value="Calibrador">Calibrador / Estándar</option>
                                    <option value="Reactivo General">Reactivo General / Tampón</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Proveedor</label>
                                <select class="form-select form-select-premium" @bind="reagentModel.SupplierId">
                                    <option value="">-- Sin proveedor --</option>
                                    @foreach (var supplier in suppliers)
                                    {
                                        <option value="@supplier.Id">@supplier.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Condiciones de Almacenamiento</label>
                                <InputText class="form-control form-control-premium" @bind-Value="reagentModel.StorageConditions" placeholder="Ej. 2-8°C, protegido de la luz" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium text-secondary">Ubicación por defecto</label>
                                <select class="form-select form-select-premium" @bind="reagentModel.DefaultLocationId">
                                    <option value="">-- Ninguna --</option>
                                    @foreach (var loc in storageLocations)
                                    {
                                        <option value="@loc.Id">@loc.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-medium text-secondary">Vida Útil Abierto (Días)</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="reagentModel.OpenShelfLifeDays" placeholder="Ej. 30" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Stock Mínimo (Alerta) *</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="reagentModel.MinStock" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Stock Objetivo *</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="reagentModel.TargetStock" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium text-secondary">Cantidad de Reorden *</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="reagentModel.ReorderQty" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(reagentError))
                        {
                            <div class="alert alert-danger p-2 small mt-3 mb-0"><i class="bi bi-exclamation-circle-fill me-1"></i> @reagentError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light" @onclick="() => showReagentModal = false">Cancelar</button>
                            <button type="submit" class="btn btn-premium px-4">Guardar Reactivo</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Registrar Nuevo Lote -->
@if (showRegisterLotModal && targetReagent != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content card shadow border-0 rounded-4 w-100">
                <div class="card-header bg-success text-white py-3 border-0 rounded-top-4 d-flex justify-content-between">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-square-fill me-2"></i>Registrar Lote de Reactivo</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showRegisterLotModal = false"></button>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium text-secondary">Reactivo Destino</label>
                        <input type="text" class="form-control bg-light" value="@(string.IsNullOrEmpty(targetReagent.Fluorescence) ? targetReagent.Name : $"{targetReagent.Name} ({targetReagent.Fluorescence})")" readonly />
                    </div>
                    <EditForm Model="lotModel" OnValidSubmit="RegisterLot">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-medium text-secondary">Número de Lote *</label>
                                <InputText class="form-control form-control-premium" @bind-Value="lotModel.LotNumber" placeholder="Ej. L104728" />
                                <ValidationMessage For="() => lotModel.LotNumber" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Fecha de Recepción *</label>
                                <InputDate class="form-control form-control-premium" @bind-Value="lotModel.ReceivedDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Fecha de Caducidad *</label>
                                <InputDate class="form-control form-control-premium" @bind-Value="lotModel.ExpiryDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Cantidad Recibida *</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="lotModel.ReceivedQty" />
                                <ValidationMessage For="() => lotModel.ReceivedQty" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Ubicación Física</label>
                                <select class="form-select form-select-premium" @bind="lotModel.LocationId">
                                    <option value="">-- Por defecto --</option>
                                    @foreach (var loc in storageLocations)
                                    {
                                        <option value="@loc.Id">@loc.Name</option>
                                    }
                                </select>
                            </div>
                            
                            <div class="col-md-12">
                                <label class="form-label fw-medium text-secondary">Leer código de barras</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-qr-code-scan text-success"></i></span>
                                    <input type="text" class="form-control form-control-premium bg-light" placeholder="Escanee el código de barras aquí..." readonly />
                                </div>
                                <small class="text-muted small-badge bg-light text-secondary border mt-1 d-inline-block">Futura implementación: extracción automática de lote y caducidad</small>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(lotError))
                        {
                            <div class="alert alert-danger p-2 small mt-3 mb-0"><i class="bi bi-exclamation-circle-fill me-1"></i> @lotError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light" @onclick="() => showRegisterLotModal = false">Cancelar</button>
                            <button type="submit" class="btn btn-premium px-4">Registrar Lote</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Ajustar Stock / Descarte / Consumo Manual -->
@if (showAdjustStockModal && targetReagentForAdjust != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content card shadow border-0 rounded-4 w-100">
                <div class="card-header bg-secondary text-white py-3 border-0 rounded-top-4 d-flex justify-content-between">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-sliders me-2"></i>Ajustar Inventario</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showAdjustStockModal = false"></button>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3 small">
                        <strong>Reactivo:</strong> @targetReagentForAdjust.Name <br />
                        @if (targetLotForAdjust != null)
                        {
                            <span><strong>Lote:</strong> @targetLotForAdjust.LotNumber (Disponible: @targetLotForAdjust.AvailableQty)</span>
                        }
                    </div>

                    <EditForm Model="adjustModel" OnValidSubmit="AdjustStock">
                        <DataAnnotationsValidator />
                        <div class="row g-3">
                            @if (targetLotForAdjust == null)
                            {
                                <div class="col-md-12">
                                    <label class="form-label fw-medium text-secondary">Seleccionar Lote *</label>
                                    <select class="form-select form-select-premium" @bind="adjustModel.ReagentLotId">
                                        <option value="">-- Seleccionar lote --</option>
                                        @foreach (var lot in targetReagentForAdjust.AvailableLots)
                                        {
                                            <option value="@lot.Id">Lote: @lot.LotNumber (Q: @lot.Qty)</option>
                                        }
                                    </select>
                                    <ValidationMessage For="() => adjustModel.ReagentLotId" class="text-danger small" />
                                </div>
                            }
                            
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Tipo de Movimiento *</label>
                                <select class="form-select form-select-premium" @bind="adjustModel.MovementType">
                                    <option value="OUT">Consumo (Salida)</option>
                                    <option value="IN">Entrada manual</option>
                                    <option value="WASTE">Descarte por caducidad (Waste)</option>
                                    <option value="ADJUST">Ajuste de inventario</option>
                                    <option value="RETURN">Devolución</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium text-secondary">Cantidad *</label>
                                <InputNumber class="form-control form-control-premium" @bind-Value="adjustModel.Qty" placeholder="Ej. 1 o 5" />
                                <ValidationMessage For="() => adjustModel.Qty" class="text-danger small" />
                                <small class="text-muted">Use valores positivos. Las salidas restarán automáticamente.</small>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-medium text-secondary">Motivo / Explicación (ISO 15189) *</label>
                                <InputText class="form-control form-control-premium" @bind-Value="adjustModel.Reason" placeholder="Ej. Consumo diario, Descarte por lote caducado, Corrección de inventario" />
                                <ValidationMessage For="() => adjustModel.Reason" class="text-danger small" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(adjustError))
                        {
                            <div class="alert alert-danger p-2 small mt-3 mb-0"><i class="bi bi-exclamation-circle-fill me-1"></i> @adjustError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light" @onclick="() => showAdjustStockModal = false">Cancelar</button>
                            <button type="submit" class="btn btn-premium px-4">Registrar Movimiento</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Historial Completo de Movimientos (Auditoría) -->
@if (showMovementsModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content card shadow border-0 rounded-4 w-100">
                <div class="card-header bg-dark text-white py-3 border-0 rounded-top-4 d-flex justify-content-between">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2"></i>Historial de Trazabilidad e Inventario</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showMovementsModal = false"></button>
                </div>
                <div class="card-body p-4" style="max-height: 70vh; overflow-y: auto;">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 small">
                            <thead class="bg-light text-muted text-uppercase">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Usuario</th>
                                    <th>Reactivo</th>
                                    <th>Lote</th>
                                    <th>Movimiento</th>
                                    <th>Cant.</th>
                                    <th>Motivo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (movements == null || !movements.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            No se han registrado movimientos de inventario.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var mov in movements)
                                    {
                                        var isPositive = mov.AdjustmentType == "IN" || mov.AdjustmentType == "RETURN";
                                        <tr>
                                            <td>@mov.MovedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                            <td>@mov.UserName</td>
                                            <td>
                                                <strong>@mov.ReagentName</strong>
                                                @if (!string.IsNullOrEmpty(mov.Fluorescence))
                                                {
                                                    <span class="badge bg-light text-info border font-monospace ms-1">@mov.Fluorescence</span>
                                                }
                                            </td>
                                            <td>@(mov.LotNumber ?? "N/A")</td>
                                            <td>
                                                <span class="badge @(isPositive ? "bg-success" : "bg-danger")">
                                                    @mov.AdjustmentType
                                                </span>
                                            </td>
                                            <td class="fw-bold @(isPositive ? "text-success" : "text-danger")">
                                                @(isPositive ? "+" : "-")@Math.Abs(mov.Qty).ToString("N2")
                                            </td>
                                            <td>@mov.Reason</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

