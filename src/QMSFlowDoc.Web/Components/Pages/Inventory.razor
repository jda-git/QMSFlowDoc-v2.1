@code {
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private string stockFilter = "all";
    private List<ReagentListDto> reagentsList = new();
    private Reagent? selectedReagent = null;
    private bool showAllLots = false;

    // Selections / Lookups
    private List<StorageLocation> storageLocations = new();
    private List<Supplier> suppliers = new();
    private List<InventoryMovementDto> movements = new();

    // Stats
    private int lowStockCount = 0;
    private int expiredOrNearExpiryCount = 0;

    // Modals visibility
    private bool showReagentModal = false;
    private bool isEditingReagent = false;
    private bool showRegisterLotModal = false;
    private bool showAdjustStockModal = false;
    private bool showMovementsModal = false;

    // Form Models
    private ReagentFormModel reagentModel = new();
    private LotFormModel lotModel = new();
    private AdjustFormModel adjustModel = new();

    // Validation Errors
    private string reagentError = string.Empty;
    private string lotError = string.Empty;
    private string adjustError = string.Empty;

    // Context for lot modal/adjust modal
    private ReagentListDto? targetReagent = null;
    private ReagentListDto? targetReagentForAdjust = null;
    private ReagentLot? targetLotForAdjust = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadInventoryDataAsync();
        storageLocations = (await InventoryService.GetStorageLocationsAsync()).ToList();
        suppliers = (await InventoryService.GetSuppliersAsync()).ToList();
    }

    private async Task LoadInventoryDataAsync()
    {
        isLoading = true;
        try
        {
            var list = await InventoryService.GetReagentsAsync();
            reagentsList = list.ToList();
            
            // Calculate statistics
            lowStockCount = reagentsList.Count(r => r.TotalStock <= r.MinStock);
            expiredOrNearExpiryCount = reagentsList.Count(r => r.ExpiryStatus > 0);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error charging reagents: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string currentSortColumn = "name";
    private bool isSortAscending = true;

    private void SortTable(string column)
    {
        if (currentSortColumn == column)
        {
            isSortAscending = !isSortAscending;
        }
        else
        {
            currentSortColumn = column;
            isSortAscending = true;
        }
    }

    private string GetSortIcon(string column)
    {
        if (currentSortColumn != column) return "bi-arrow-down-up opacity-50";
        return isSortAscending ? "bi-caret-up-fill text-success" : "bi-caret-down-fill text-success";
    }

    private IEnumerable<ReagentListDto> FilteredReagents
    {
        get
        {
            var query = reagentsList.Where(r => 
                (string.IsNullOrEmpty(searchTerm) || 
                 r.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                 (r.InternalCode != null && r.InternalCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
                 (r.Manufacturer != null && r.Manufacturer.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                && (stockFilter == "all" || 
                    (stockFilter == "active" && r.Status == QMSFlowDoc.Shared.Models.ReagentStatus.ACTIVO) || 
                    (stockFilter == "low" && r.TotalStock <= r.MinStock))
            );

            return currentSortColumn switch
            {
                "code" => isSortAscending ? query.OrderBy(r => r.InternalCode ?? "") : query.OrderByDescending(r => r.InternalCode ?? ""),
                "name" => isSortAscending ? query.OrderBy(r => r.Name) : query.OrderByDescending(r => r.Name),
                "fluorescence" => isSortAscending ? query.OrderBy(r => r.Fluorescence ?? "") : query.OrderByDescending(r => r.Fluorescence ?? ""),
                "type" => isSortAscending ? query.OrderBy(r => r.ReagentType) : query.OrderByDescending(r => r.ReagentType),
                "supplier" => isSortAscending ? query.OrderBy(r => r.SupplierName ?? "") : query.OrderByDescending(r => r.SupplierName ?? ""),
                "stock" => isSortAscending ? query.OrderBy(r => r.TotalStock) : query.OrderByDescending(r => r.TotalStock),
                "expiry" => isSortAscending ? query.OrderBy(r => r.NearestExpiry ?? DateTime.MaxValue) : query.OrderByDescending(r => r.NearestExpiry ?? DateTime.MinValue),
                _ => query
            };
        }
    }

    private async Task SelectReagent(Guid reagentId)
    {
        selectedReagent = await InventoryService.GetReagentByIdAsync(reagentId);
    }

    private string GetExpiryBadgeClass(int status) => status switch
    {
        2 => "bg-danger text-white",
        1 => "bg-warning text-dark",
        _ => "bg-success text-white"
    };

    private string GetLotStatusColorClass(LotStatus status) => status switch
    {
        LotStatus.RELEASED => "status-released",
        LotStatus.QUARANTINE => "status-quarantine",
        LotStatus.IN_USE => "status-in-use",
        LotStatus.BLOCKED => "status-blocked",
        LotStatus.CONSUMED => "status-consumed",
        LotStatus.EXPIRED => "status-expired",
        LotStatus.RECALLED => "status-recalled",
        _ => "bg-light text-dark"
    };

    private async Task UpdateLotStatus(ReagentLot lot, string? newStatusStr)
    {
        if (Enum.TryParse<LotStatus>(newStatusStr, out var status))
        {
            var success = await InventoryService.UpdateLotStatusAsync(lot.Id, (QMSFlowDoc.Domain.Entities.LotStatus)status, null, "Usuario Web");
            if (success)
            {
                if (selectedReagent != null)
                {
                    await SelectReagent(selectedReagent.Id);
                }
                await LoadInventoryDataAsync();
            }
        }
    }

    private async Task QuickConsumeLot(ReagentLot lot, decimal quantity)
    {
        var request = new AdjustStockRequest(
            lot.ReagentId,
            lot.Id,
            QMSFlowDoc.Shared.Models.InventoryMovementType.OUT,
            -quantity,
            "Descuento rápido por consumo clínico",
            "Consumo rápido",
            null
        );

        var success = await InventoryService.AdjustStockAsync(request);
        if (success)
        {
            if (selectedReagent != null)
            {
                await SelectReagent(selectedReagent.Id);
            }
            await LoadInventoryDataAsync();
        }
    }

    // MODAL OPENERS

    private void OpenAddReagentModal()
    {
        reagentModel = new ReagentFormModel();
        isEditingReagent = false;
        reagentError = string.Empty;
        showReagentModal = true;
    }

    private void OpenEditReagentModal(ReagentListDto reagent)
    {
        reagentModel = new ReagentFormModel
        {
            Id = reagent.Id,
            Name = reagent.Name,
            Manufacturer = reagent.Manufacturer,
            Reference = reagent.Reference,
            ReagentType = reagent.ReagentType,
            Classification = reagent.Classification ?? "Anticuerpo Monoclonal",
            Fluorescence = reagent.Fluorescence,
            InternalCode = reagent.InternalCode,
            MinStock = reagent.MinStock,
            TargetStock = reagent.TargetStock
        };

        // Find details to load other fields
        var fullReagent = reagentsList.FirstOrDefault(r => r.Id == reagent.Id);
        if (fullReagent != null)
        {
            reagentModel.OpenShelfLifeDays = 30; // default/placeholder
        }

        isEditingReagent = true;
        reagentError = string.Empty;
        showReagentModal = true;
    }

    private void OpenRegisterLotModal(ReagentListDto? reagent)
    {
        targetReagent = reagent ?? (selectedReagent != null ? reagentsList.FirstOrDefault(r => r.Id == selectedReagent.Id) : null);
        if (targetReagent == null) return;

        lotModel = new LotFormModel
        {
            ReagentId = targetReagent.Id,
            ReceivedDate = DateTime.Today,
            ExpiryDate = DateTime.Today.AddYears(1),
            ReceivedQty = 10
        };

        lotError = string.Empty;
        showRegisterLotModal = true;
    }

    private void OpenAdjustStockModal(ReagentListDto? reagent, ReagentLot? lot)
    {
        targetReagentForAdjust = reagent ?? (selectedReagent != null ? reagentsList.FirstOrDefault(r => r.Id == selectedReagent.Id) : null);
        if (targetReagentForAdjust == null && lot != null)
        {
            targetReagentForAdjust = reagentsList.FirstOrDefault(r => r.Id == lot.ReagentId);
        }
        if (targetReagentForAdjust == null) return;

        targetLotForAdjust = lot;
        adjustModel = new AdjustFormModel
        {
            ReagentId = targetReagentForAdjust.Id,
            ReagentLotId = lot?.Id ?? Guid.Empty,
            MovementType = QMSFlowDoc.Shared.Models.InventoryMovementType.OUT,
            Qty = 1,
            Reason = string.Empty
        };

        adjustError = string.Empty;
        showAdjustStockModal = true;
    }

    private async Task OpenMovementsModal()
    {
        movements = await InventoryService.GetMovementsAsync(null, null, null, null);
        showMovementsModal = true;
    }

    // SAVING LOGIC

    private async Task SaveReagent()
    {
        reagentError = string.Empty;
        try
        {
            var req = new CreateReagentRequest(
                reagentModel.Name,
                reagentModel.Manufacturer,
                reagentModel.SupplierId,
                reagentModel.ManufacturerCode,
                reagentModel.InternalCode,
                reagentModel.Fluorescence,
                reagentModel.ReagentType,
                reagentModel.Reference,
                reagentModel.Classification,
                reagentModel.StorageConditions,
                reagentModel.DefaultLocationId,
                reagentModel.OpenShelfLifeDays,
                reagentModel.MinStock,
                reagentModel.TargetStock,
                reagentModel.ReorderQty
            );

            if (isEditingReagent && reagentModel.Id.HasValue)
            {
                var ok = await InventoryService.UpdateReagentAsync(reagentModel.Id.Value, req);
                if (!ok) reagentError = "Error al actualizar el reactivo.";
            }
            else
            {
                var created = await InventoryService.CreateReagentAsync(req);
                if (created == null) reagentError = "Error al registrar el reactivo.";
            }

            if (string.IsNullOrEmpty(reagentError))
            {
                showReagentModal = false;
                await LoadInventoryDataAsync();
                if (selectedReagent != null)
                {
                    await SelectReagent(selectedReagent.Id);
                }
            }
        }
        catch (Exception ex)
        {
            reagentError = $"Error: {ex.Message}";
        }
    }

    private async Task RegisterLot()
    {
        lotError = string.Empty;
        if (targetReagent == null) return;
        try
        {
            var req = new RegisterLotRequest(
                targetReagent.Id,
                lotModel.LotNumber,
                lotModel.ExpiryDate,
                lotModel.ReceivedDate,
                lotModel.ReceivedQty,
                lotModel.LocationId,
                null,
                null
            );

            var lots = await InventoryService.RegisterLotAsync(req);
            if (lots == null)
            {
                lotError = "Error al registrar el lote.";
            }
            else
            {
                showRegisterLotModal = false;
                await LoadInventoryDataAsync();
                if (selectedReagent != null && selectedReagent.Id == targetReagent.Id)
                {
                    await SelectReagent(selectedReagent.Id);
                }
            }
        }
        catch (Exception ex)
        {
            lotError = $"Error: {ex.Message}";
        }
    }

    private async Task AdjustStock()
    {
        adjustError = string.Empty;
        if (targetReagentForAdjust == null) return;

        var lotId = targetLotForAdjust?.Id ?? adjustModel.ReagentLotId;
        if (lotId == Guid.Empty)
        {
            adjustError = "Debe seleccionar un lote.";
            return;
        }

        try
        {
            // Adjust sign for OUT/WASTE
            var qty = adjustModel.Qty;
            if (adjustModel.MovementType == QMSFlowDoc.Shared.Models.InventoryMovementType.OUT || adjustModel.MovementType == QMSFlowDoc.Shared.Models.InventoryMovementType.WASTE)
            {
                qty = -Math.Abs(qty);
            }
            else
            {
                qty = Math.Abs(qty);
            }

            var req = new AdjustStockRequest(
                targetReagentForAdjust.Id,
                lotId,
                (QMSFlowDoc.Shared.Models.InventoryMovementType)adjustModel.MovementType,
                qty,
                adjustModel.Reason,
                "Ajuste manual",
                null
            );

            var ok = await InventoryService.AdjustStockAsync(req);
            if (!ok)
            {
                adjustError = "Error al realizar el ajuste de inventario.";
            }
            else
            {
                showAdjustStockModal = false;
                await LoadInventoryDataAsync();
                if (selectedReagent != null && selectedReagent.Id == targetReagentForAdjust.Id)
                {
                    await SelectReagent(selectedReagent.Id);
                }
            }
        }
        catch (Exception ex)
        {
            adjustError = $"Error: {ex.Message}";
        }
    }

    private async Task ConfirmDeleteReagent(ReagentListDto reagent)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de que desea eliminar el reactivo '{reagent.Name}'?");
        if (confirm)
        {
            var success = await InventoryService.DeleteReagentAsync(reagent.Id);
            if (success)
            {
                if (selectedReagent?.Id == reagent.Id)
                {
                    selectedReagent = null;
                }
                await LoadInventoryDataAsync();
            }
        }
    }

