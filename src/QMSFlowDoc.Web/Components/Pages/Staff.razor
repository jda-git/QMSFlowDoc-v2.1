@page "/staff"
@rendermode InteractiveServer
@using QMSFlowDoc.Application.Services.Staff
@using QMSFlowDoc.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@using QMSFlowDoc.Application.Services.Identity
@attribute [Authorize]
@inject IStaffService StaffService
@inject IJSRuntime JS
@inject IPermissionService PermissionService

<PageTitle>Personal y Formación (ISO 15189) - QMSFlowDoc</PageTitle>

@if (!canRead)
{
    <div class="staff-container py-4">
        <div class="alert alert-danger p-4 rounded-4 shadow-sm border border-danger border-opacity-25 mt-4 text-center">
            <i class="bi bi-shield-slash-fill fs-1 text-danger d-block mb-3"></i>
            <h4 class="fw-bold">Acceso No Autorizado</h4>
            <p class="text-muted mb-0">Su rol de usuario no tiene permisos de lectura para acceder a Personal y Formación.</p>
        </div>
    </div>
}
else
{
    <div class="staff-container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1"><i class="bi bi-people-fill text-primary me-2"></i>Personal y Formación</h1>
            <p class="text-muted mb-0">Gestión de expedientes, capacitación técnica, evaluación de competencias y autorizaciones clínicas.</p>
        </div>
        <div class="d-flex gap-2">
            @if (canCreate)
            {
                <button class="btn btn-premium px-4" @onclick="OpenAddStaffModal">
                    <i class="bi bi-person-plus-fill me-2"></i> Registrar Empleado
                </button>
            }
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Personal Registrado</span>
                        <h3 class="fw-bold mb-0">@staffList.Count</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2.5">
                        <i class="bi bi-person-badge fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Formación Registrada</span>
                        <h3 class="fw-bold mb-0">@trainingActivities.Count</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info rounded p-2.5">
                        <i class="bi bi-journal-bookmark-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Evaluaciones Competencia</span>
                        <h3 class="fw-bold mb-0">@competencyCatalog.Count</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded p-2.5">
                        <i class="bi bi-shield-check fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Autorizaciones Clínicas</span>
                        <h3 class="fw-bold mb-0 text-warning">@authorizationsCatalog.Count</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 text-warning rounded p-2.5">
                        <i class="bi bi-pen-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-tabs custom-tabs mb-4 border-bottom-0">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "staff" ? "active text-primary fw-semibold" : "text-secondary")"
                    @onclick='() => SetTab("staff")'>
                <i class="bi bi-people-fill me-2"></i>Plantilla de Personal
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "training" ? "active text-primary fw-semibold" : "text-secondary")"
                    @onclick='() => SetTab("training")'>
                <i class="bi bi-book-half me-2"></i>Actividades Formativas
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "competencies" ? "active text-primary fw-semibold" : "text-secondary")"
                    @onclick='() => SetTab("competencies")'>
                <i class="bi bi-award-fill me-2"></i>Catálogo de Competencias
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "authorizations" ? "active text-primary fw-semibold" : "text-secondary")"
                    @onclick='() => SetTab("authorizations")'>
                <i class="bi bi-file-earmark-lock2-fill me-2"></i>Catálogo de Autorizaciones
            </button>
        </li>
    </ul>

    <!-- Main Content Area -->
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white border">
        @if (activeTab == "staff")
        {
            <div class="row mb-3 g-3 align-items-center justify-content-between">
                <div class="col-md-6 col-lg-5">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control form-control-premium border-start-0 ps-1"
                               placeholder="Buscar por nombre, cargo, dpto..."
                               @bind="searchTerm" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-4 col-lg-3">
                    <div class="form-check form-switch pt-2">
                        <input class="form-check-input" type="checkbox" id="showInactive" @bind="showInactive" @bind:after="LoadData" />
                        <label class="form-check-label text-muted small" for="showInactive">Mostrar personal de baja</label>
                    </div>
                </div>
            </div>

            <!-- Staff Grid -->
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">Nombre</th>
                            <th>Cargo</th>
                            <th>Departamento</th>
                            <th>Autorizaciones</th>
                            <th>Formaciones</th>
                            <th>Estado</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredStaff.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-people fs-1 d-block mb-3 opacity-50"></i>
                                    No se encontraron empleados registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var staff in FilteredStaff)
                            {
                                <tr class="cursor-pointer" @onclick="() => SelectStaff(staff.Id)">
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width: 40px; height: 40px;">
                                                @staff.FullName.Substring(0, Math.Min(2, staff.FullName.Length)).ToUpper()
                                            </div>
                                            <div>
                                                <span class="fw-semibold text-dark d-block">@staff.FullName</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="fw-medium text-secondary">@staff.PositionTitle</span></td>
                                    <td><span class="badge bg-light text-secondary border">@staff.Department</span></td>
                                    <td>
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-2 py-1">
                                            <i class="bi bi-file-earmark-lock2-fill me-1"></i>@staff.CompetencyPassCount activas
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-20 px-2 py-1">
                                            <i class="bi bi-mortarboard-fill me-1"></i>@staff.TrainingCount aptas
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @(staff.IsActive ? "bg-success bg-opacity-10 text-success border border-success border-opacity-20" : "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20")">
                                            @(staff.IsActive ? "Activo" : "Baja")
                                        </span>
                                    </td>
                                    <td class="text-end pe-3" @onclick:stopPropagation="true">
                                        @if (canRead)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm rounded-3 px-3 me-1" @onclick="() => SelectStaff(staff.Id)">
                                                <i class="bi bi-eye"></i> Expediente
                                            </button>
                                        }
                                        @if (canEdit)
                                        {
                                            <button class="btn btn-light btn-sm rounded-3 border px-2.5" @onclick="() => EditStaffProfile(staff)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (activeTab == "training")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@trainingActivities.Count actividades de formación registradas</span>
                @if (canCreate)
                {
                    <button class="btn btn-outline-primary btn-sm px-3" @onclick="OpenAddTrainingModal">
                        <i class="bi bi-plus-circle me-1"></i> Nueva Actividad
                    </button>
                }
            </div>

            <!-- Training Activities Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">Título de Actividad</th>
                            <th>Proveedor</th>
                            <th>Tipo</th>
                            <th>Modalidad</th>
                            <th>Fechas</th>
                            <th>Horas</th>
                            <th>Inscritos</th>
                            <th>Validado por</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var act in trainingActivities)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold text-dark">@act.Title</td>
                                <td class="text-secondary">@act.Provider</td>
                                <td><span class="badge bg-light text-primary border">@act.TrainingTypeName</span></td>
                                <td><span class="badge bg-light text-secondary border">@act.Modality</span></td>
                                <td class="text-muted small">@act.StartDate?.ToString("dd/MM/yyyy") - @act.EndDate?.ToString("dd/MM/yyyy")</td>
                                <td class="fw-medium text-dark">@act.Hours.ToString("N1") hrs</td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-2 py-1">
                                        <i class="bi bi-people me-1"></i>@act.AssignedStaffCount aptos
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-person-check-fill text-success me-1"></i>@act.CreatedByUserName
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-sm btn-outline-primary px-3 rounded-3" @onclick="() => OpenAssignTrainingModal(act)">
                                            <i class="bi bi-person-plus-fill me-1"></i> Asignar
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (activeTab == "competencies")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@competencyCatalog.Count competencias en catálogo</span>
                @if (canCreate)
                {
                    <button class="btn btn-outline-success btn-sm px-3" @onclick="OpenAddCompetencyCatalogModal">
                        <i class="bi bi-plus-circle me-1"></i> Nueva Competencia
                    </button>
                }
            </div>

            <!-- Competency Catalog Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">Código</th>
                            <th>Nombre de Competencia</th>
                            <th>Área</th>
                            <th>Subárea</th>
                            <th>Ámbito de Rol</th>
                            <th>Vigencia (Meses)</th>
                            <th>Validado por</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var comp in competencyCatalog)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-success font-monospace">@comp.Code</td>
                                <td class="fw-semibold text-dark">@comp.Name</td>
                                <td><span class="badge bg-light text-secondary border">@comp.Area</span></td>
                                <td class="text-muted">@comp.SubArea</td>
                                <td><span class="badge bg-light text-info border">@comp.RoleScope</span></td>
                                <td class="text-dark">@comp.DefaultReassessmentMonths meses</td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="bi bi-person-check-fill text-success me-1"></i>@comp.CreatedByUserName
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-light btn-sm rounded-3 border px-2.5 me-1" @onclick="() => OpenEditCompetencyCatalogModal(comp)" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                    @if (canDelete)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-3 px-2.5" @onclick="() => ConfirmDeleteCompetencyCatalog(comp)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else if (activeTab == "authorizations")
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">@authorizationsCatalog.Count autorizaciones clínicas definidas</span>
                @if (canCreate)
                {
                    <button class="btn btn-outline-warning btn-sm text-dark px-3 fw-medium" @onclick="OpenAddAuthorizationCatalogModal">
                        <i class="bi bi-plus-circle me-1"></i> Nueva Autorización
                    </button>
                }
            </div>

            <!-- Authorizations Catalog Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">Código</th>
                            <th>Nombre de Autorización</th>
                            <th>Descripción</th>
                            <th>Requiere Competencia</th>
                            <th>Ámbito de Rol</th>
                            <th>Valoración Habilidades</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var auth in authorizationsCatalog)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-warning font-monospace">@auth.Code</td>
                                <td class="fw-semibold text-dark">@auth.Name</td>
                                <td class="text-muted text-wrap" style="max-width: 300px;">@auth.Description</td>
                                <td>
                                    <span class="badge rounded-pill @(auth.RequiresCompetency ? "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20" : "bg-light text-secondary border")">
                                        @(auth.RequiresCompetency ? "Sí" : "No")
                                    </span>
                                    @if (auth.RequiresCompetency && !string.IsNullOrEmpty(auth.RequiredCompetencyName))
                                    {
                                        <div class="small text-muted mt-1" style="font-size: 0.75rem;">
                                            <i class="bi bi-shield-check text-success me-1"></i>@auth.RequiredCompetencyName
                                        </div>
                                    }
                                </td>
                                <td><span class="badge bg-light text-info border">@auth.RoleScope</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(auth.AssessmentMethod))
                                    {
                                        <div class="small text-dark fw-medium">
                                            <i class="bi bi-eye-fill text-primary me-1"></i>@auth.AssessmentMethod
                                        </div>
                                    }
                                    <div class="small text-muted mt-1" style="font-size: 0.75rem;">
                                        <i class="bi bi-person-check-fill text-success me-1"></i>Validado por: @auth.CreatedByUserName
                                    </div>
                                </td>
                                <td class="text-end pe-3">
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-light btn-sm rounded-3 border px-2.5 me-1" @onclick="() => OpenEditAuthorizationCatalogModal(auth)" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                    }
                                    @if (canDelete)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-3 px-2.5" @onclick="() => ConfirmDeleteAuthorizationCatalog(auth)" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- DRAWER: EXPEDIENTE DETALLADO DEL EMPLEADO -->
@if (selectedStaffDetail != null)
{
    <div class="drawer-overlay" @onclick="CloseDrawer"></div>
    <div class="drawer shadow-lg animate-slide-left p-4">
        <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
            <div>
                <div class="d-flex align-items-center">
                    <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold fs-4" style="width: 50px; height: 50px;">
                        @selectedStaffDetail.FullName.Substring(0, Math.Min(2, selectedStaffDetail.FullName.Length)).ToUpper()
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark mb-0">@selectedStaffDetail.FullName</h4>
                        <span class="text-muted small">@selectedStaffDetail.PositionTitle — @selectedStaffDetail.Department</span>
                    </div>
                </div>
            </div>
            <button type="button" class="btn-close" @onclick="CloseDrawer"></button>
        </div>

        <ul class="nav nav-pills custom-pills mb-4 bg-light p-1 rounded-3">
            <li class="nav-item flex-fill">
                <button class="nav-link w-100 text-center @(drawerTab == "training" ? "active" : "")" @onclick='() => SetDrawerTab("training")'>
                    Formación
                </button>
            </li>
            <li class="nav-item flex-fill">
                <button class="nav-link w-100 text-center @(drawerTab == "competencies" ? "active" : "")" @onclick='() => SetDrawerTab("competencies")'>
                    Competencias
                </button>
            </li>
            <li class="nav-item flex-fill">
                <button class="nav-link w-100 text-center @(drawerTab == "authorizations" ? "active" : "")" @onclick='() => SetDrawerTab("authorizations")'>
                    Autorizaciones
                </button>
            </li>
        </ul>

        <div class="drawer-content" style="max-height: calc(100vh - 240px); overflow-y: auto;">
            @if (drawerTab == "training")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Historial de Capacitación</h5>
                </div>
                @if (!selectedStaffDetail.Trainings.Any())
                {
                    <p class="text-muted small text-center py-4">No hay formaciones asignadas.</p>
                }
                else
                {
                    @foreach (var tr in selectedStaffDetail.Trainings)
                    {
                        <div class="card border-0 bg-light p-3 rounded-3 mb-3">
                            <h6 class="fw-semibold text-dark mb-1">@tr.Title</h6>
                            <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                                <span>Proveedor: <strong>@tr.Provider</strong></span>
                                <span>Resultado: <strong class="text-success">@tr.Result</strong></span>
                            </div>
                            <div class="text-end mt-2 small">
                                <span class="text-muted me-3">Completado: @tr.CompletionDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    }
                }
            }
            @if (drawerTab == "competencies")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Evaluaciones de Competencia</h5>
                    @if (canEdit)
                    {
                        <button class="btn btn-primary btn-sm px-3" @onclick="OpenAddEvaluationModal">
                            <i class="bi bi-shield-plus me-1"></i> Evaluar
                        </button>
                    }
                </div>
                @if (!selectedStaffDetail.CompetencyEvaluations.Any())
                {
                    <p class="text-muted small text-center py-4">Sin evaluaciones registradas.</p>
                }
                else
                {
                    @foreach (var ev in selectedStaffDetail.CompetencyEvaluations)
                    {
                        <div class="card border-0 bg-light p-3 rounded-3 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold text-success small">@ev.Area</span>
                                <span class="badge rounded-pill @(ev.Outcome == "COMPETENTE" || ev.Outcome == "PASS" ? "bg-success text-white" : "bg-danger text-white")">
                                    @ev.Outcome
                                </span>
                            </div>
                            <h6 class="fw-semibold text-dark">@ev.CompetencyName</h6>
                            <p class="text-muted small mb-2">@ev.Evidence</p>
                            <div class="d-flex justify-content-between align-items-center small text-muted">
                                <span>Evaluado por: @ev.EvaluatorName</span>
                                <span>Vence: @ev.ValidUntil?.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    }
                }
            }
            @if (drawerTab == "authorizations")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Firmas y Procesos Autorizados</h5>
                    @if (canEdit)
                    {
                        <button class="btn btn-warning btn-sm text-dark px-3 fw-medium" @onclick="OpenAddAuthorizationModal">
                            <i class="bi bi-key me-1"></i> Autorizar
                        </button>
                    }
                </div>
                @if (!selectedStaffDetail.Authorizations.Any())
                {
                    <p class="text-muted small text-center py-4">Sin autorizaciones vigentes.</p>
                }
                else
                {
                    @foreach (var auth in selectedStaffDetail.Authorizations)
                    {
                        <div class="card border-0 bg-light p-3 rounded-3 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="badge bg-success rounded-pill">@auth.Status</span>
                            </div>
                            <h6 class="fw-semibold text-dark">@auth.AuthorizationName</h6>
                            <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                                <span>Autorizó: @auth.GrantedByName</span>
                                <span>Vence: @auth.ValidUntil?.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    }
                }
            }
