            <div class="modal-content card shadow border-0 rounded-4">
                <div class="card-header bg-danger text-white py-3 border-0 rounded-top-4">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>¿Eliminar Autorización?</h6>
                </div>
                <div class="card-body p-3">
                    <p class="small text-secondary mb-3">
                        ¿Está seguro de que desea eliminar la autorización <strong>@deletingAuthorizationCatalog?.Code</strong> del catálogo? Las concesiones activas se preservarán, pero no se podrán otorgar nuevas.
                    </p>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-light btn-sm" @onclick="() => showDeleteAuthorizationCatalogConfirm = false">Cancelar</button>
                        <button type="button" class="btn btn-danger btn-sm px-3 text-white" @onclick="DeleteAuthorizationCatalog">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
}

