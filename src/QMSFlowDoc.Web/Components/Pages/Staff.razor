@code {
    private string activeTab = "staff";
    private string drawerTab = "training";
    private string searchTerm = string.Empty;
    private bool showInactive = false;

    private List<StaffListDto> staffList = new();
    private List<TrainingActivityExtendedDto> trainingActivities = new();
    private List<CompetencyCatalogDto> competencyCatalog = new();
    private List<AuthorizationCatalogDto> authorizationsCatalog = new();
    private List<TrainingTypeCatalogDto> trainingTypeCatalog = new();
    private List<UserLookupDto> usersLookup = new();

    private readonly List<string> assessmentMethodsList = new()
    {
        "observación directa de la actividad",
        "revisión de los registros de trabajo",
        "evaluación de la capacidad para resolver problemas",
        "análisis de muestras ciegas/controles"
    };

    private StaffExpedienteDto? selectedStaffDetail;

    // Modals visibility
    private bool showStaffModal = false;
    private bool showTrainingModal = false;
    private bool showAssignTrainingModal = false;
    private bool showEvaluationModal = false;
    private bool showAuthorizationModal = false;
    private bool showCompetencyCatalogModal = false;
    private bool showAuthorizationCatalogModal = false;
    private bool showDeleteCompetencyCatalogConfirm = false;
    private bool showDeleteAuthorizationCatalogConfirm = false;

    private bool isEditingStaff = false;
    private bool isEditingCompetencyCatalog = false;
    private bool isEditingAuthorizationCatalog = false;

    private CompetencyCatalogDto? deletingCompetencyCatalog;
    private AuthorizationCatalogDto? deletingAuthorizationCatalog;
    private string? catalogErrorMessage;

    private bool canRead = false;
    private bool canCreate = false;
    private bool canEdit = false;
    private bool canDelete = false;
    private bool canPrint = false;

    // Form Models
    private StaffModel staffModel = new();
    private TrainingModel trainingModel = new();
    private CompetencyCatalogModel competencyCatalogModel = new();
    private AuthorizationCatalogModel authorizationCatalogModel = new();
    private AssignmentModel assignmentModel = new();
    private EvaluationModel evaluationModel = new();
    private GrantModel grantModel = new();

    private TrainingActivityExtendedDto? selectedActivity;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }
    private Guid? currentUserId = null;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var uId))
            {
                currentUserId = uId;
            }

            var userPermissions = await PermissionService.GetPermissionsForUserAsync(user, "Staff");
            canRead = userPermissions.CanRead;
            canCreate = userPermissions.CanCreate;
            canEdit = userPermissions.CanEdit;
            canDelete = userPermissions.CanDelete;
            canPrint = userPermissions.CanPrint;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        staffList = await StaffService.GetStaffListAsync(showInactive);
        trainingActivities = await StaffService.GetTrainingActivitiesAsync();
        competencyCatalog = await StaffService.GetCompetencyCatalogAsync();
        authorizationsCatalog = await StaffService.GetAuthorizationCatalogAsync();
        trainingTypeCatalog = await StaffService.GetTrainingTypeCatalogAsync();
        usersLookup = await StaffService.GetAvailableUsersLookupAsync();
    }

    private void SetTab(string tab)
    {
        activeTab = tab;
    }

    private void SetDrawerTab(string tab)
    {
        drawerTab = tab;
    }

    private async Task SelectStaff(Guid staffId)
    {
        selectedStaffDetail = await StaffService.GetStaffExpedienteAsync(staffId);
        drawerTab = "training";
    }

    private void CloseDrawer()
    {
        selectedStaffDetail = null;
    }

    private IEnumerable<StaffListDto> FilteredStaff =>
        staffList.Where(s =>
            string.IsNullOrEmpty(searchTerm) ||
            s.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (s.PositionTitle != null && s.PositionTitle.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (s.Department != null && s.Department.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        );

    // MODAL TRIGGERS

    private void OpenAddStaffModal()
    {
        isEditingStaff = false;
        staffModel = new StaffModel { IsActive = true, HiredAt = DateTime.Today };
        showStaffModal = true;
    }

    private void EditStaffProfile(StaffListDto profile)
    {
        isEditingStaff = true;
        staffModel = new StaffModel
        {
            Id = profile.Id,
            UserId = profile.UserId?.ToString() ?? "",
            PositionTitle = profile.PositionTitle ?? "",
            Department = profile.Department ?? "",
            HiredAt = DateTime.Today, // default placeholder or query detail if needed
            IsActive = profile.IsActive
        };
        showStaffModal = true;
    }

    private async Task SaveStaffProfile()
    {
        if (isEditingStaff && !canEdit) return;
        if (!isEditingStaff && !canCreate) return;
        Guid? uId = string.IsNullOrEmpty(staffModel.UserId) ? null : Guid.Parse(staffModel.UserId);
        var req = new CreateStaffProfileRequest(uId ?? Guid.Empty, staffModel.PositionTitle, staffModel.Department, staffModel.HiredAt);

        if (isEditingStaff && staffModel.Id.HasValue)
        {
            // En V2 original update profile logic or delete/recreate can be invoked
            // For now update positional info
            var updateReq = new UpdateStaffProfileRequest(
                staffModel.Id.Value,
                "", // Will fetch or preserve fullname inside service
                null,
                staffModel.PositionTitle,
                staffModel.Department,
                staffModel.HiredAt,
                "",
                staffModel.IsActive
            );
            // Si el servicio no tiene update completo, usamos Create/Update combinados
            await StaffService.UpdateStaffProfileAsync(staffModel.Id.Value, req);
        }
        else
        {
            await StaffService.CreateStaffProfileAsync(req);
        }

        showStaffModal = false;
        await LoadData();
    }

    private void OpenAddTrainingModal()
    {
        trainingModel = new TrainingModel { StartDate = DateTime.Today, EndDate = DateTime.Today, Hours = 8 };
        showTrainingModal = true;
    }

    private async Task SaveTrainingActivity()
    {
        if (!canCreate) return;
        if (trainingModel.TrainingTypeId == Guid.Empty) return;

        var req = new CreateTrainingActivityRequest(
            trainingModel.Title,
            trainingModel.Provider,
            trainingModel.TrainingTypeId,
            trainingModel.Modality,
            trainingModel.StartDate,
            trainingModel.EndDate,
            trainingModel.Hours,
            trainingModel.Description,
            trainingModel.IsInternal,
            currentUserId
        );

        await StaffService.CreateTrainingActivityAsync(req);
        showTrainingModal = false;
        await LoadData();
    }

    private void OpenAssignTrainingModal(TrainingActivityExtendedDto act)
    {
        selectedActivity = act;
        assignmentModel = new AssignmentModel
        {
            TrainingActivityId = act.Id,
            ParticipationRole = "ASISTENTE",
            Result = "APTO",
            CompletionDate = DateTime.Today
        };
        showAssignTrainingModal = true;
    }

    private async Task SaveAssignment()
    {
        if (!canEdit) return;
        if (assignmentModel.StaffId == Guid.Empty) return;

        var req = new AssignStaffTrainingRequest(
            assignmentModel.StaffId,
            assignmentModel.TrainingActivityId,
            assignmentModel.ParticipationRole,
            assignmentModel.Result,
            assignmentModel.Score,
            assignmentModel.CompletionDate,
            null,
            assignmentModel.Notes
        );

        await StaffService.AssignTrainingAsync(req);
        showAssignTrainingModal = false;
        await LoadData();
    }

    private void OpenAddEvaluationModal()
    {
        if (selectedStaffDetail == null) return;
        evaluationModel = new EvaluationModel
        {
            StaffId = selectedStaffDetail.Id,
            EvaluationDate = DateTime.Today,
            Outcome = "COMPETENTE"
        };
        showEvaluationModal = true;
    }

    private async Task SaveCompetencyEvaluation()
    {
        if (!canEdit) return;
        if (evaluationModel.CompetencyId == Guid.Empty || evaluationModel.EvaluatorStaffId == Guid.Empty) return;

        var comp = competencyCatalog.First(c => c.Id == evaluationModel.CompetencyId);
        var outcomeEnum = evaluationModel.Outcome == "COMPETENTE" ? QMSFlowDoc.Shared.Models.CompetencyOutcome.PASS : QMSFlowDoc.Shared.Models.CompetencyOutcome.FAIL;

        var req = new AssessCompetencyRequest(
            evaluationModel.StaffId,
            comp.Name,
            comp.Area,
            outcomeEnum,
            evaluationModel.EvaluationDate,
            evaluationModel.EvaluationDate.AddMonths(comp.DefaultReassessmentMonths),
            evaluationModel.Findings,
            evaluationModel.EvaluatorStaffId
        );

        await StaffService.RecordCompetencyEvaluationAsync(req);
        showEvaluationModal = false;
        if (selectedStaffDetail != null)
        {
            await SelectStaff(selectedStaffDetail.Id);
        }
        await LoadData();
    }

    private void OpenAddAuthorizationModal()
    {
        if (selectedStaffDetail == null) return;
        grantModel = new GrantModel
        {
            StaffId = selectedStaffDetail.Id,
            ValidFrom = DateTime.Today
        };
        showAuthorizationModal = true;
    }

    private async Task SaveAuthorization()
    {
        if (!canEdit) return;
        if (grantModel.AuthorizationId == Guid.Empty) return;

        var auth = authorizationsCatalog.First(a => a.Id == grantModel.AuthorizationId);
        Guid grantedBy = currentUserId ?? usersLookup.FirstOrDefault()?.Id ?? Guid.Empty;

        var req = new GrantAuthorizationRequest(
            grantModel.StaffId,
            auth.Name,
            auth.Description,
            grantModel.ValidFrom,
            grantModel.ValidUntil,
            grantedBy,
            null,
            null
        );

        await StaffService.GrantAuthorizationAsync(req);
        showAuthorizationModal = false;
        if (selectedStaffDetail != null)
        {
            await SelectStaff(selectedStaffDetail.Id);
        }
        await LoadData();
    }

    // Competency Catalog Handlers
    private void OpenAddCompetencyCatalogModal()
    {
        competencyCatalogModel = new CompetencyCatalogModel
        {
            DefaultReassessmentMonths = 12,
            RoleScope = "AMBOS"
        };
        isEditingCompetencyCatalog = false;
        showCompetencyCatalogModal = true;
    }

    private void OpenEditCompetencyCatalogModal(CompetencyCatalogDto comp)
    {
        competencyCatalogModel = new CompetencyCatalogModel
        {
            Id = comp.Id,
            Code = comp.Code,
            Name = comp.Name,
            Description = comp.Description,
            RoleScope = comp.RoleScope,
            Area = comp.Area,
            SubArea = comp.SubArea,
            DefaultReassessmentMonths = comp.DefaultReassessmentMonths
        };
        isEditingCompetencyCatalog = true;
        showCompetencyCatalogModal = true;
    }

    private async Task SaveCompetencyCatalog()
    {
        if (isEditingCompetencyCatalog && !canEdit) return;
        if (!isEditingCompetencyCatalog && !canCreate) return;
        var req = new CreateCompetencyCatalogRequest(
            competencyCatalogModel.Code,
            competencyCatalogModel.Name,
            competencyCatalogModel.Description,
            competencyCatalogModel.RoleScope,
            competencyCatalogModel.Area,
            competencyCatalogModel.SubArea,
            competencyCatalogModel.DefaultReassessmentMonths,
            currentUserId
        );

        if (isEditingCompetencyCatalog && competencyCatalogModel.Id.HasValue)
        {
            await StaffService.UpdateCompetencyCatalogAsync(competencyCatalogModel.Id.Value, req);
        }
        else
        {
            await StaffService.CreateCompetencyCatalogAsync(req);
        }

        showCompetencyCatalogModal = false;
        await LoadData();
    }

    private void ConfirmDeleteCompetencyCatalog(CompetencyCatalogDto comp)
    {
        deletingCompetencyCatalog = comp;
        showDeleteCompetencyCatalogConfirm = true;
    }

    private async Task DeleteCompetencyCatalog()
    {
        if (!canDelete) return;
        if (deletingCompetencyCatalog != null)
        {
            await StaffService.DeleteCompetencyCatalogAsync(deletingCompetencyCatalog.Id);
            showDeleteCompetencyCatalogConfirm = false;
            await LoadData();
        }
    }

    // Authorization Catalog Handlers
    private void OpenAddAuthorizationCatalogModal()
    {
        catalogErrorMessage = null;
        authorizationCatalogModel = new AuthorizationCatalogModel
        {
            RoleScope = "AMBOS",
            RequiresCompetency = false,
            RequiredCompetencyId = null,
            AssessmentMethod = ""
        };
        isEditingAuthorizationCatalog = false;
        showAuthorizationCatalogModal = true;
    }

    private void OpenEditAuthorizationCatalogModal(AuthorizationCatalogDto auth)
    {
        catalogErrorMessage = null;
        authorizationCatalogModel = new AuthorizationCatalogModel
        {
            Id = auth.Id,
            Code = auth.Code,
            Name = auth.Name,
            Description = auth.Description,
            RoleScope = auth.RoleScope,
            RequiresCompetency = auth.RequiresCompetency,
            ValidityMonths = auth.ValidityMonths,
            RequiredCompetencyId = auth.RequiredCompetencyId,
            AssessmentMethod = auth.AssessmentMethod
        };
        isEditingAuthorizationCatalog = true;
        showAuthorizationCatalogModal = true;
    }

    private async Task SaveAuthorizationCatalog()
    {
        if (isEditingAuthorizationCatalog && !canEdit) return;
        if (!isEditingAuthorizationCatalog && !canCreate) return;
        if (string.IsNullOrEmpty(authorizationCatalogModel.AssessmentMethod))
        {
            catalogErrorMessage = "Debe seleccionar un método de valoración de habilidades.";
            return;
        }

        if (authorizationCatalogModel.RequiresCompetency && 
            (!authorizationCatalogModel.RequiredCompetencyId.HasValue || authorizationCatalogModel.RequiredCompetencyId.Value == Guid.Empty))
        {
            catalogErrorMessage = "Debe vincular una competencia si activa el requisito de competencia previa.";
            return;
        }

        catalogErrorMessage = null;

        var req = new CreateAuthorizationCatalogRequest(
            authorizationCatalogModel.Code,
            authorizationCatalogModel.Name,
            authorizationCatalogModel.Description,
            authorizationCatalogModel.RoleScope,
            authorizationCatalogModel.RequiresCompetency,
            authorizationCatalogModel.ValidityMonths,
            authorizationCatalogModel.RequiresCompetency ? authorizationCatalogModel.RequiredCompetencyId : null,
            currentUserId,
            authorizationCatalogModel.AssessmentMethod
        );

        if (isEditingAuthorizationCatalog && authorizationCatalogModel.Id.HasValue)
        {
            await StaffService.UpdateAuthorizationCatalogAsync(authorizationCatalogModel.Id.Value, req);
        }
        else
        {
            await StaffService.CreateAuthorizationCatalogAsync(req);
        }

        showAuthorizationCatalogModal = false;
        await LoadData();
    }

    private void ConfirmDeleteAuthorizationCatalog(AuthorizationCatalogDto auth)
    {
        deletingAuthorizationCatalog = auth;
        showDeleteAuthorizationCatalogConfirm = true;
    }

    private async Task DeleteAuthorizationCatalog()
    {
        if (!canDelete) return;
        if (deletingAuthorizationCatalog != null)
        {
            await StaffService.DeleteAuthorizationCatalogAsync(deletingAuthorizationCatalog.Id);
            showDeleteAuthorizationCatalogConfirm = false;
            await LoadData();
        }
    }

    // INTERNAL MODELS

    public class StaffModel
    {
        public Guid? Id { get; set; }
        public string UserId { get; set; } = string.Empty;
        public string PositionTitle { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public DateTime? HiredAt { get; set; }
        public bool IsActive { get; set; } = true;
    }

    public class TrainingModel
    {
        public string Title { get; set; } = string.Empty;
        public string? Provider { get; set; }
        public Guid TrainingTypeId { get; set; }
        public string Modality { get; set; } = "PRESENCIAL";
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public decimal Hours { get; set; }
        public string? Credits { get; set; }
        public string? Description { get; set; }
        public bool IsInternal { get; set; }
        public string? InternalDepartment { get; set; }
    }

    public class AssignmentModel
    {
        public Guid StaffId { get; set; }
        public Guid TrainingActivityId { get; set; }
        public string ParticipationRole { get; set; } = "ASISTENTE";
        public string? Result { get; set; } = "APTO";
        public string? Score { get; set; }
        public DateTime? CompletionDate { get; set; }
        public string? Notes { get; set; }
    }

    public class EvaluationModel
    {
        public Guid StaffId { get; set; }
        public Guid CompetencyId { get; set; }
        public DateTime EvaluationDate { get; set; }
        public Guid EvaluatorStaffId { get; set; }
        public string Outcome { get; set; } = "COMPETENTE";
        public string? Findings { get; set; }
        public string? CorrectiveActions { get; set; }
    }

    public class GrantModel
    {
        public Guid StaffId { get; set; }
        public Guid AuthorizationId { get; set; }
        public DateTime ValidFrom { get; set; }
        public DateTime? ValidUntil { get; set; }
    }

    public class CompetencyCatalogModel
    {
        public Guid? Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string RoleScope { get; set; } = "AMBOS";
        public string Area { get; set; } = string.Empty;
        public string? SubArea { get; set; }
        public int DefaultReassessmentMonths { get; set; } = 12;
    }

    public class AuthorizationCatalogModel
    {
        public Guid? Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string RoleScope { get; set; } = "AMBOS";
        public bool RequiresCompetency { get; set; }
        public int? ValidityMonths { get; set; }
        public Guid? RequiredCompetencyId { get; set; }
        public string? AssessmentMethod { get; set; }
    }
}
