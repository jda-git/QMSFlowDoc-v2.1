                <div class="card-body p-3">
                    <p class="small text-secondary mb-3">
                        ¿Está seguro de que desea eliminar la competencia <strong>@deletingCompetencyCatalog?.Code</strong> del catálogo? Esta acción no eliminará las evaluaciones previas pero sí ocultará la competencia del catálogo.
                    </p>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-light btn-sm" @onclick="() => showDeleteCompetencyCatalogConfirm = false">Cancelar</button>
                        <button type="button" class="btn btn-danger btn-sm px-3 text-white" @onclick="DeleteCompetencyCatalog">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- MODAL DE CONFIRMACIÓN DE ELIMINACIÓN DE AUTORIZACIÓN -->
@if (showDeleteAuthorizationCatalogConfirm)
{
