@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private Guid currentUserId = Guid.Empty;
    private string currentUserName = "";
    private bool canRead = false;
    private bool canCreate = false;
    private bool canEdit = false;
    private bool canDelete = false;
    private bool canPrint = false;

    private List<EquipmentListDto> equipments = new();
    private EquipmentDashboardDto dashboard = new();
    private EquipmentDetailDto? details = null;

    private Guid? selectedId = null;
    private string searchTerm = "";
    private string filterCriticidad = "";
    private string filterCategory = "";
    private string filterStatus = "";
    private string filterAptitude = "";
    private bool showOnlyAlerts = false;

    private string detailTab = "info";

    // Modals visibility
    private bool showCreateEditModal = false;
    private bool isEditing = false;
    private string selectedSpecType = "";

    private bool showAcceptanceWizard = false;
    private int acceptanceStep = 1;

    private bool showStatusOverrideModal = false;
    private EquipmentStatus overrideStatus = EquipmentStatus.IN_SERVICE;
    private string overrideReason = "";
    private string statusValidationMessage = "";

    private bool showQCDialog = false;
    private bool showRegisterMaintModal = false;
    private bool showAddCalPlanModal = false;
    private bool showAddCalRecordModal = false;
    private bool showIncidentModal = false;
    private bool showRegisterRepairModal = false;
    private bool showImpactModal = false;
    private bool showDecommissionModal = false;

    // Form Models
    private CreateEquipmentRequest formModel = new();
    private RegisterAcceptanceRequest acceptanceModel = new();
    private CreateDailyQCRequest qcModel = new();
    private RegisterMaintenanceRequest maintModel = new();
    private RegisterCalibrationPlanRequest calPlanModel = new();
    private RegisterCalibrationRecordRequest calRecordModel = new();
    private RegisterIncidentRequest incidentModel = new();
    private RegisterRepairRequest repairModel = new();
    private RegisterImpactRequest impactModel = new();
    private RegisterDecommissionRequest decommissionModel = new();

    private IEnumerable<EquipmentListDto> filteredEquipments =>
        equipments.Where(e =>
            (string.IsNullOrWhiteSpace(searchTerm) || 
             e.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
             (e.InternalId ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
             (e.SerialNumber ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
             (string.IsNullOrWhiteSpace(filterCriticidad) || e.Criticidad.ToString() == filterCriticidad) &&
             (string.IsNullOrWhiteSpace(filterStatus) || e.Status.ToString() == filterStatus) &&
             (string.IsNullOrWhiteSpace(filterAptitude) || e.Aptitude.ToString() == filterAptitude) &&
             (string.IsNullOrWhiteSpace(filterCategory) || MatchesCategory(e, filterCategory)) &&
             (!showOnlyAlerts || e.ActiveAlertCount > 0)
        );

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            currentUserName = user.Identity?.Name ?? "Usuario";
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var uId))
                currentUserId = uId;

            var perms = await PermissionService.GetPermissionsForUserAsync(user, "Equipment");
            canRead = perms.CanRead;
            canCreate = perms.CanCreate;
            canEdit = perms.CanEdit;
            canDelete = perms.CanDelete;
            canPrint = perms.CanPrint;
        }

        if (canRead)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        equipments = await EquipmentService.GetEquipmentsAsync();
        dashboard = await EquipmentService.GetDashboardStatsAsync();
        if (selectedId.HasValue)
        {
            details = await EquipmentService.GetEquipmentDetailsAsync(selectedId.Value);
        }
    }

    private async Task SelectEquipment(Guid id)
    {
        selectedId = id;
        details = await EquipmentService.GetEquipmentDetailsAsync(id);
        detailTab = "info";
    }

    private bool MatchesCategory(EquipmentListDto eq, string category)
    {
        if (category == "Citómetro")
            return eq.Name.Contains("Citómetro", StringComparison.OrdinalIgnoreCase) || (eq.Restrictions ?? "").Contains("Citómetro", StringComparison.OrdinalIgnoreCase);
        if (category == "Pipeta")
            return eq.Name.Contains("Pipeta", StringComparison.OrdinalIgnoreCase) || eq.Name.Contains("Micropipeta", StringComparison.OrdinalIgnoreCase);
        if (category == "Nevera")
            return eq.Name.Contains("Nevera", StringComparison.OrdinalIgnoreCase) || eq.Name.Contains("Congelador", StringComparison.OrdinalIgnoreCase);
        if (category == "Centrífuga")
            return eq.Name.Contains("Centrífuga", StringComparison.OrdinalIgnoreCase);
        if (category == "Software")
            return eq.Name.Contains("Software", StringComparison.OrdinalIgnoreCase) || eq.Name.Contains("Infinicyt", StringComparison.OrdinalIgnoreCase) || eq.Name.Contains("Kaluza", StringComparison.OrdinalIgnoreCase);
        if (category == "Auxiliar")
            return eq.Criticidad == EquipmentCriticidad.AUXILIARY;
        return true;
    }

    private string GetCriticidadLabel(EquipmentCriticidad criticidad) => criticidad switch
    {
        EquipmentCriticidad.CRITICAL => "Crítico",
        EquipmentCriticidad.SEMICRITICAL => "Semicrítico",
        EquipmentCriticidad.AUXILIARY => "Auxiliar",
        EquipmentCriticidad.NON_CRITICAL => "No Crítico",
        _ => criticidad.ToString()
    };

    private string GetCriticidadBadgeClass(EquipmentCriticidad criticidad) => criticidad switch
    {
        EquipmentCriticidad.CRITICAL => "bg-danger",
        EquipmentCriticidad.SEMICRITICAL => "bg-warning text-dark",
        EquipmentCriticidad.AUXILIARY => "bg-info text-dark",
        EquipmentCriticidad.NON_CRITICAL => "bg-secondary",
        _ => "bg-dark"
    };

    private string GetStatusBadgeClass(EquipmentStatus status) => status switch
    {
        EquipmentStatus.IN_SERVICE => "bg-success",
        EquipmentStatus.IN_SERVICE_WITH_RESTRICTIONS => "bg-info text-dark",
        EquipmentStatus.PENDING_QC_VERIFICATION => "bg-warning text-dark",
        EquipmentStatus.OUT_OF_SERVICE => "bg-danger",
        EquipmentStatus.IN_QUARANTINE => "bg-danger",
        EquipmentStatus.DECOMMISSIONED => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetAptitudeBadgeClass(EquipmentAptitude aptitude) => aptitude switch
    {
        EquipmentAptitude.APTO => "bg-success-soft text-success border border-success border-opacity-25",
        EquipmentAptitude.CON_RESTRICCIONES => "bg-warning-soft text-warning border border-warning border-opacity-25",
        EquipmentAptitude.NO_APTO => "bg-danger-soft text-danger border border-danger border-opacity-25",
        _ => "bg-light text-dark"
    };

    private void OpenCreateModal()
    {
        formModel = new CreateEquipmentRequest();
        selectedSpecType = "";
        isEditing = false;
        showCreateEditModal = true;
    }

    private void OpenEditModal()
    {
        if (details == null) return;
        var eq = details.Equipment;
        formModel = new UpdateEquipmentRequest
        {
            Id = eq.Id,
            Name = eq.Name,
            InternalId = eq.InternalId,
            AssetTag = eq.AssetTag,
            Manufacturer = eq.Manufacturer,
            Model = eq.Model,
            SerialNumber = eq.SerialNumber,
            Location = eq.Location,
            AreaLaboratorio = eq.AreaLaboratorio,
            Criticidad = (EquipmentCriticidad)eq.Criticidad,
            IntendedUse = eq.IntendedUse,
            InstalledAt = eq.InstalledAt,
            PurchaseDate = eq.PurchaseDate,
            WarrantyUntil = eq.WarrantyUntil,
            Notes = eq.Notes,
            
            // Specs
            CytoType = eq.CytoType,
            CytoLasersCount = eq.CytoLasersCount,
            CytoWavelengths = eq.CytoWavelengths,
            CytoDetectorsCount = eq.CytoDetectorsCount,
            CytoAcquisitionSoftware = eq.CytoAcquisitionSoftware,
            CytoAssociatedComputer = eq.CytoAssociatedComputer,
            CytoFcsExportPath = eq.CytoFcsExportPath,

            PipetteType = eq.PipetteType,
            PipetteNominalVolume = eq.PipetteNominalVolume,
            PipetteVolumeRange = eq.PipetteVolumeRange,
            PipetteEmpLimit = eq.PipetteEmpLimit,

            ColdTempMin = eq.ColdTempMin,
            ColdTempMax = eq.ColdTempMax,
            ColdSensorAssociated = eq.ColdSensorAssociated,
            ColdTempRecordType = eq.ColdTempRecordType,

            SoftName = eq.SoftName,
            SoftVersion = eq.SoftVersion,
            SoftValidationState = eq.SoftValidationState
        };

        if (!string.IsNullOrEmpty(eq.CytoType)) selectedSpecType = "CYTOMETER";
        else if (!string.IsNullOrEmpty(eq.PipetteType)) selectedSpecType = "PIPETTE";
        else if (eq.ColdTempMin.HasValue) selectedSpecType = "COLD";
        else if (!string.IsNullOrEmpty(eq.SoftName)) selectedSpecType = "SOFTWARE";
        else selectedSpecType = "";

        isEditing = true;
        showCreateEditModal = true;
    }

    private void CloseCreateModal()
    {
        showCreateEditModal = false;
    }

    private async Task SaveEquipment()
    {
        try
        {
            if (isEditing)
            {
                var updateReq = (UpdateEquipmentRequest)formModel;
                await EquipmentService.UpdateEquipmentAsync(updateReq.Id, updateReq, currentUserId, currentUserName);
            }
            else
            {
                var newId = await EquipmentService.CreateEquipmentAsync(formModel, currentUserId, currentUserName);
                selectedId = newId;
            }
            showCreateEditModal = false;
            await LoadData();
            if (selectedId.HasValue)
            {
                await SelectEquipment(selectedId.Value);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al guardar equipo: {ex.Message}");
        }
    }

    private void OpenAcceptanceWizard()
    {
        if (details == null) return;
        acceptanceModel = new RegisterAcceptanceRequest
        {
            EquipmentId = details.Equipment.Id,
            ReceptionDate = DateTime.Today,
            InstallationDate = DateTime.Today,
            AcceptanceDate = DateTime.Today,
            ServiceEntryDate = DateTime.Today,
            AcceptanceOutcome = "Aceptado",
            PackagingCorrect = true,
            AmbientConditionsCorrect = true,
            ConnectionsCorrect = true,
            InitialPowerOnCorrect = true,
            SoftwareCommunicationCorrect = true,
            CriteriaDefined = true
        };
        acceptanceStep = 1;
        showAcceptanceWizard = true;
    }

    private void PrevAcceptanceStep() => acceptanceStep--;
    private async Task SaveAcceptanceStep()
    {
        if (acceptanceStep < 3)
        {
            acceptanceStep++;
        }
        else
        {
            // Submit
            try
            {
                var ok = await EquipmentService.RegisterAcceptanceAsync(acceptanceModel, currentUserId, currentUserName);
                if (ok)
                {
                    showAcceptanceWizard = false;
                    await LoadData();
                    await JS.InvokeVoidAsync("alert", "Registro de aceptación completado correctamente. El equipo ha sido dado de alta en servicio.");
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Error al guardar aceptación: {ex.Message}");
            }
        }
    }

    private void OpenStatusOverrideModal()
    {
        if (details == null) return;
        overrideStatus = (EquipmentStatus)details.Equipment.Status;
        overrideReason = "";
        statusValidationMessage = "";
        showStatusOverrideModal = true;
    }

    private async Task SaveStatusOverride()
    {
        if (details == null) return;
        if (string.IsNullOrWhiteSpace(overrideReason))
        {
            statusValidationMessage = "La justificación del cambio de estado es obligatoria.";
            return;
        }

        try
        {
            var ok = await EquipmentService.UpdateEquipmentStatusAsync(details.Equipment.Id, overrideStatus, overrideReason, currentUserId);
            if (ok)
            {
                showStatusOverrideModal = false;
                await LoadData();
            }
            else
            {
                statusValidationMessage = "Transición de estado no autorizada. Verifique las reglas ISO (ej. Equipos críticos requieren aceptación previa antes de ser puestos en servicio).";
            }
        }
        catch (Exception ex)
        {
            statusValidationMessage = $"Error: {ex.Message}";
        }
    }

