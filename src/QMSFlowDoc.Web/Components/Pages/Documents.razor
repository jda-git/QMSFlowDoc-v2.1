@code {
    private bool isAdmin = false;
    private bool canRead = false;
    private bool canCreate = false;
    private bool canEdit = false;
    private bool canDelete = false;
    private bool canPrint = false;
    private List<FolderDto> folders = new();
    private List<DocumentType> documentTypes = new();
    private List<DocumentDto> allDocuments = new();
    
    private Guid? folderModalParentId = null;

    private class FolderNode
    {
        public FolderDto Folder { get; set; } = null!;
        public int Depth { get; set; }
    }

    private List<FolderNode> displayedFolders = new();

    private void BuildFolderTree(List<FolderDto> allFolders, Guid? parentId, int depth)
    {
        var children = allFolders.Where(f => f.ParentFolderId == parentId).OrderBy(f => f.Name).ToList();
        foreach (var child in children)
        {
            displayedFolders.Add(new FolderNode { Folder = child, Depth = depth });
            BuildFolderTree(allFolders, child.Id, depth + 1);
        }
    }
    
    private bool isLoading = true;
    private Guid? selectedFolderId = null;
    private string searchTerm = string.Empty;
    private bool includeObsolete = false;
    
    private DocumentDto? selectedDoc = null;
    private Document? selectedDocument = null; // Full entity with versions
    
    // Auth context
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }
    private Guid? currentUserId = null;
    private string currentUsername = "Usuario Web";

    // Filters logic
    private IEnumerable<DocumentDto> FilteredDocuments => allDocuments
        .Where(d => selectedFolderId == null || d.FolderId == selectedFolderId)
        .Where(d => includeObsolete || d.Status != QMSFlowDoc.Shared.Models.DocumentStatus.OBSOLETE)
        .Where(d => string.IsNullOrEmpty(searchTerm) || 
                   d.DocCode.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                   d.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    // Modals visibility toggles
    private bool showFolderModal = false;
    private Guid? editingFolderId = null;
    private string folderModalName = string.Empty;
    private string folderError = string.Empty;

    private bool showAddDocumentModal = false;
    private string newDocCode = string.Empty;
    private string newDocTitle = string.Empty;
    private Guid? newDocTypeId = null;
    private Guid? newDocFolderId = null;
    private string newDocArea = string.Empty;
    private string newDocProcess = string.Empty;
    private int newDocReviewInterval = 12;
    private string newDocVersionLabel = "1.0";
    private IBrowserFile? newDocFile = null;
    private string addDocError = string.Empty;
    private bool isUploading = false;

    private bool showEditMetadataModal = false;
    private Document? editingDoc = null;
    private Guid? editingDocTypeId = null;
    private Guid? editingDocFolderId = null;
    private int editingReviewInterval = 12;
    private DocumentStatus editingDocStatus;
    private string editMetadataError = string.Empty;

    private bool showAddVersionModal = false;
    private string newVersionLabel = string.Empty;
    private string newVersionChangeSummary = string.Empty;
    private IBrowserFile? newVersionFile = null;
    private string addVersionError = string.Empty;

    private bool showApproveModal = false;
    private string approveComments = string.Empty;
    private string approveError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Obtain logged in user details
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            currentUsername = user.Identity?.Name ?? "Usuario Web";
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var uId))
            {
                currentUserId = uId;
            }
            isAdmin = user.IsInRole("Administrador");

            var userPermissions = await PermissionService.GetPermissionsForUserAsync(user, "Documents");
            canRead = userPermissions.CanRead;
            canCreate = userPermissions.CanCreate;
            canEdit = userPermissions.CanEdit;
            canDelete = userPermissions.CanDelete;
            canPrint = userPermissions.CanPrint;
        }

        await LoadFoldersAsync();
        await LoadDocumentTypesAsync();
        await LoadDocumentsAsync();
    }

    private async Task LoadFoldersAsync()
    {
        var allFolders = (await FolderService.GetAllFoldersAsync()).ToList();
        displayedFolders.Clear();
        BuildFolderTree(allFolders, null, 0);
        folders = allFolders;
    }

    private async Task LoadDocumentTypesAsync()
    {
        documentTypes = (await DocumentService.GetDocumentTypesAsync()).ToList();
        if (documentTypes.Any() && newDocTypeId == null)
        {
            newDocTypeId = documentTypes.First().Id;
        }
    }

    private async Task LoadDocumentsAsync()
    {
        isLoading = true;
        allDocuments = (await DocumentService.GetDocumentsAsync(true)).ToList(); // Get all to filter in-memory
        foreach (var doc in allDocuments)
        {
            Console.WriteLine($"[DEBUG Documents.razor] DocCode: {doc.DocCode}, Title: {doc.Title}, DtoStatus: {doc.Status}");
        }
        isLoading = false;
    }

    private void SelectFolder(FolderDto? folder)
    {
        selectedFolderId = folder?.Id;
        selectedDoc = null;
        selectedDocument = null;
    }

    private async Task SelectDocument(Guid docId)
    {
        selectedDocument = await DocumentService.GetDocumentByIdAsync(docId);
        selectedDoc = allDocuments.FirstOrDefault(d => d.Id == docId);
    }

    private string GetStatusBadgeClass(QMSFlowDoc.Shared.Models.DocumentStatus status) => status switch
    {
        QMSFlowDoc.Shared.Models.DocumentStatus.DRAFT => "bg-warning text-dark border",
        QMSFlowDoc.Shared.Models.DocumentStatus.REVIEW => "bg-info text-white shadow-sm",
        QMSFlowDoc.Shared.Models.DocumentStatus.APPROVED => "bg-success text-white shadow-sm",
        QMSFlowDoc.Shared.Models.DocumentStatus.OBSOLETE => "bg-danger text-white shadow-sm",
        _ => "bg-secondary text-white"
    };

    private string GetStatusBadgeClass(DocumentStatus status) => status switch
    {
        DocumentStatus.DRAFT => "bg-warning text-dark border",
        DocumentStatus.REVIEW => "bg-info text-white shadow-sm",
        DocumentStatus.APPROVED => "bg-success text-white shadow-sm",
        DocumentStatus.OBSOLETE => "bg-danger text-white shadow-sm",
        _ => "bg-secondary text-white"
    };

    private string GetStatusText(QMSFlowDoc.Shared.Models.DocumentStatus status)
    {
        Console.WriteLine($"[DEBUG Documents.razor] GetStatusText(Shared.DocumentStatus) called with: {status} ({(int)status})");
        return status switch
        {
            QMSFlowDoc.Shared.Models.DocumentStatus.DRAFT => "Borrador",
            QMSFlowDoc.Shared.Models.DocumentStatus.REVIEW => "En Revisión",
            QMSFlowDoc.Shared.Models.DocumentStatus.APPROVED => "Vigente",
            QMSFlowDoc.Shared.Models.DocumentStatus.OBSOLETE => "Obsoleto",
            _ => status.ToString()
        };
    }

    private string GetStatusText(DocumentStatus status)
    {
        Console.WriteLine($"[DEBUG Documents.razor] GetStatusText(Domain.DocumentStatus) called with: {status} ({(int)status})");
        return status switch
        {
            DocumentStatus.DRAFT => "Borrador",
            DocumentStatus.REVIEW => "En Revisión",
            DocumentStatus.APPROVED => "Vigente",
            DocumentStatus.OBSOLETE => "Obsoleto",
            _ => status.ToString()
        };
    }

    // FOLDER CRUD
    private void OpenAddFolderModal()
    {
        editingFolderId = null;
        folderModalName = string.Empty;
        folderModalParentId = selectedFolderId;
        folderError = string.Empty;
        showFolderModal = true;
    }

    private void OpenRenameFolderModal(FolderDto folder)
    {
        editingFolderId = folder.Id;
        folderModalName = folder.Name;
        folderModalParentId = folder.ParentFolderId;
        folderError = string.Empty;
        showFolderModal = true;
    }

    private async Task SaveFolder()
    {
        if (editingFolderId.HasValue && !canEdit)
        {
            folderError = "No tiene permisos para renombrar carpetas.";
            return;
        }
        if (!editingFolderId.HasValue && !canCreate)
        {
            folderError = "No tiene permisos para crear carpetas.";
            return;
        }
        if (string.IsNullOrWhiteSpace(folderModalName))
        {
            folderError = "El nombre de la carpeta es requerido.";
            return;
        }

        try
        {
            bool success;
            if (editingFolderId.HasValue)
            {
                success = await FolderService.RenameFolderAsync(editingFolderId.Value, folderModalName, folderModalParentId);
            }
            else
            {
                success = await FolderService.CreateFolderAsync(folderModalName, folderModalParentId);
            }

            if (success)
            {
                showFolderModal = false;
                await LoadFoldersAsync();
            }
            else
            {
                folderError = "No se pudo guardar la carpeta.";
            }
        }
        catch (Exception ex)
        {
            folderError = ex.Message;
        }
    }

    private async Task DeleteFolder(Guid id)
    {
        if (!canDelete)
        {
            await JS.InvokeVoidAsync("alert", "Error: No tiene permisos para eliminar carpetas.");
            return;
        }

        try
        {
            bool success = await FolderService.DeleteFolderAsync(id);
            if (success)
            {
                if (selectedFolderId == id) selectedFolderId = null;
                await LoadFoldersAsync();
                await LoadDocumentsAsync();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    // DOCUMENT CRUD
    private void OpenAddDocumentModal()
    {
        newDocCode = string.Empty;
        newDocTitle = string.Empty;
        newDocArea = string.Empty;
        newDocProcess = string.Empty;
        newDocReviewInterval = 12;
        newDocVersionLabel = "1.0";
        newDocFile = null;
        newDocFolderId = selectedFolderId;
        addDocError = string.Empty;
        isUploading = false;
        showAddDocumentModal = true;
    }

    private void OnNewDocFileSelected(InputFileChangeEventArgs e)
    {
        newDocFile = e.File;
        addDocError = string.Empty;
    }

    private async Task SaveDocument()
    {
        if (!canCreate)
        {
            addDocError = "No tiene permisos para registrar documentos.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newDocCode) || string.IsNullOrWhiteSpace(newDocTitle))
        {
            addDocError = "El código y el título son obligatorios.";
            return;
        }

        if (newDocFile == null)
        {
            addDocError = "Debe seleccionar un archivo PDF para el documento.";
            return;
        }

        isUploading = true;
        addDocError = string.Empty;

        try
        {
            // 1. Create document entry
            var request = new CreateDocumentRequest(
                newDocCode.Trim(),
                newDocTitle.Trim(),
                newDocTypeId,
                newDocFolderId,
                string.IsNullOrWhiteSpace(newDocArea) ? null : newDocArea.Trim(),
                string.IsNullOrWhiteSpace(newDocProcess) ? null : newDocProcess.Trim(),
                newDocReviewInterval,
                newDocVersionLabel,
                QMSFlowDoc.Shared.Models.DocumentStatus.DRAFT
            );

            var createdDoc = await DocumentService.CreateDocumentAsync(request, currentUserId);
            if (createdDoc != null)
            {
                // 2. Upload file bytes
                using var stream = newDocFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                
                var fileBytes = ms.ToArray();
                var uploadSuccess = await DocumentService.UploadFileAsync(
                    createdDoc.Id, 
                    fileBytes, 
                    newDocFile.Name, 
                    newDocFile.ContentType, 
                    newDocVersionLabel, 
                    "Archivo de versión inicial", 
                    currentUserId, 
                    currentUsername);

                if (uploadSuccess)
                {
                    showAddDocumentModal = false;
                    await LoadDocumentsAsync();
                    await LoadFoldersAsync(); // Recalculate document counts
                }
                else
                {
                    addDocError = "Se guardaron los metadatos pero falló la subida del archivo PDF.";
                }
            }
            else
            {
                addDocError = "No se pudo crear el documento.";
            }
        }
        catch (Exception ex)
        {
            addDocError = ex.Message;
        }
        finally
        {
            isUploading = false;
        }
    }

    private void OpenEditMetadataModal()
    {
        if (selectedDocument != null)
        {
            editingDoc = new Document
            {
                Id = selectedDocument.Id,
                DocCode = selectedDocument.DocCode,
                Title = selectedDocument.Title,
                Area = selectedDocument.Area,
                Process = selectedDocument.Process
            };
            editingDocTypeId = selectedDocument.DocumentTypeId;
            editingDocFolderId = selectedDocument.FolderId;
            editingReviewInterval = selectedDocument.ReviewIntervalMonths ?? 12;
            editingDocStatus = selectedDocument.Status;
            editMetadataError = string.Empty;
            showEditMetadataModal = true;
        }
    }

    private async Task SaveMetadataChanges()
    {
        if (editingDoc == null) return;
        if (!canEdit)
        {
            editMetadataError = "No tiene permisos para modificar metadatos.";
            return;
        }
        if (string.IsNullOrWhiteSpace(editingDoc.DocCode) || string.IsNullOrWhiteSpace(editingDoc.Title))
        {
            editMetadataError = "El código y el título son obligatorios.";
            return;
        }

        try
        {
            var request = new CreateDocumentRequest(
                editingDoc.DocCode.Trim(),
                editingDoc.Title.Trim(),
                editingDocTypeId,
                editingDocFolderId,
                string.IsNullOrWhiteSpace(editingDoc.Area) ? null : editingDoc.Area.Trim(),
                string.IsNullOrWhiteSpace(editingDoc.Process) ? null : editingDoc.Process.Trim(),
                editingReviewInterval,
                null,
                (QMSFlowDoc.Shared.Models.DocumentStatus)editingDocStatus
            );

            var success = await DocumentService.UpdateDocumentAsync(editingDoc.Id, request, currentUserId, currentUsername);
            if (success)
            {
                showEditMetadataModal = false;
                await LoadDocumentsAsync();
                await SelectDocument(editingDoc.Id); // Refresh selected document detail view
                await LoadFoldersAsync(); // Recalculate document counts
            }
            else
            {
                editMetadataError = "No se pudieron actualizar los metadatos.";
            }
        }
        catch (Exception ex)
        {
            editMetadataError = ex.Message;
        }
    }

    private async Task ConfirmDeleteDocument(DocumentDto doc)
    {
        if (!canDelete)
        {
            await JS.InvokeVoidAsync("alert", "Error: No tiene permisos para eliminar documentos.");
            return;
        }
        var confirm = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de que desea eliminar el documento '{doc.Title}' ({doc.DocCode})?");
        if (confirm)
        {
            var success = await DocumentService.DeleteDocumentAsync(doc.Id, currentUserId, currentUsername);
            if (success)
            {
                if (selectedDocument?.Id == doc.Id)
                {
                    selectedDocument = null;
                    selectedDoc = null;
                }
                await LoadDocumentsAsync();
                await LoadFoldersAsync(); // Recalculate document counts
            }
        }
    }

    // VERSION UPLOAD
    private void OpenAddVersionModal()
    {
        newVersionLabel = string.Empty;
        newVersionChangeSummary = string.Empty;
        newVersionFile = null;
        addVersionError = string.Empty;
        isUploading = false;
        showAddVersionModal = true;
    }

    private void OnNewVersionFileSelected(InputFileChangeEventArgs e)
    {
        newVersionFile = e.File;
        addVersionError = string.Empty;
    }

    private async Task SaveNewVersion()
    {
        if (selectedDocument == null) return;
        if (!canEdit)
        {
            addVersionError = "No tiene permisos para subir una nueva versión.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newVersionLabel) || string.IsNullOrWhiteSpace(newVersionChangeSummary))
        {
            addVersionError = "La etiqueta de versión y el resumen del cambio son obligatorios.";
            return;
        }
        if (newVersionFile == null)
        {
            addVersionError = "Debe cargar un archivo PDF de reemplazo.";
            return;
        }

        isUploading = true;
        addVersionError = string.Empty;

        try
        {
            using var stream = newVersionFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB limit
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            
            var fileBytes = ms.ToArray();
            var success = await DocumentService.UploadFileAsync(
                selectedDocument.Id, 
                fileBytes, 
                newVersionFile.Name, 
                newVersionFile.ContentType, 
                newVersionLabel.Trim(), 
                newVersionChangeSummary.Trim(), 
                currentUserId, 
                currentUsername);

            if (success)
            {
                showAddVersionModal = false;
                await LoadDocumentsAsync();
                await SelectDocument(selectedDocument.Id); // Refresh selected document detail view
            }
            else
            {
                addVersionError = "No se pudo cargar la nueva versión.";
            }
        }
        catch (Exception ex)
        {
            addVersionError = ex.Message;
        }
        finally
        {
            isUploading = false;
        }
    }

    // APPROVAL WORKFLOW
    private void OpenApproveModal()
    {
        approveComments = string.Empty;
        approveError = string.Empty;
        showApproveModal = true;
    }

    private async Task ApproveDocument()
    {
        if (selectedDocument == null) return;
        if (!canEdit)
        {
            approveError = "No tiene permisos para aprobar documentos.";
            return;
        }
        if (string.IsNullOrWhiteSpace(approveComments))
        {
            approveError = "Debe ingresar comentarios de aprobación para auditar la firma.";
            return;
        }

        try
        {
            var success = await DocumentService.UpdateStatusAsync(
                selectedDocument.Id, 
                DocumentStatus.APPROVED, 
                approveComments.Trim(), 
                currentUserId, 
                currentUsername);

            if (success)
            {
                showApproveModal = false;
                await LoadDocumentsAsync();
                await SelectDocument(selectedDocument.Id); // Refresh selected document detail view
            }
            else
            {
                approveError = "No se pudo cambiar el estado de aprobación.";
            }
        }
        catch (Exception ex)
        {
            approveError = ex.Message;
        }
    }
}
