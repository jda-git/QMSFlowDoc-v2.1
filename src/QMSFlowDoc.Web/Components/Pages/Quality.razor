@code {
    private string activeTab = "nc";
    private string ncSearchTerm = string.Empty;
    private string ncStatusFilter = string.Empty;
    private string ncSeverityFilter = string.Empty;
    private string complaintSearchTerm = string.Empty;

    private List<NCListDto> ncList = new();
    private List<ComplaintListDto> complaintList = new();

    private Nonconformity? selectedNC;
    private Complaint? selectedComplaint;

    // Modals
    private bool showNCModal = false;
    private bool showCAPAModal = false;
    private bool showComplaintModal = false;
    private bool showDeleteConfirm = false;
    private bool isEditingNC = false;
    private Guid? editingNCId;
    private bool isEditingComplaint = false;
    private Guid? editingComplaintId;
    private string? ncErrorMessage;
    private string deleteConfirmMessage = "";
    private Func<Task>? deleteAction;

    // Permissions
    private bool canRead = false;
    private bool canCreate = false;
    private bool canEdit = false;
    private bool canDelete = false;
    private bool canPrint = false;

    // Form Models
    private NCFormModel ncModel = new();
    private CAPAFormModel capaModel = new();
    private ComplaintFormModel complaintModel = new();

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }
    private Guid? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && Guid.TryParse(userIdClaim.Value, out var uId))
                currentUserId = uId;

            var perms = await PermissionService.GetPermissionsForUserAsync(user, "Quality");
            canRead = perms.CanRead;
            canCreate = perms.CanCreate;
            canEdit = perms.CanEdit;
            canDelete = perms.CanDelete;
            canPrint = perms.CanPrint;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        ncList = await QualityService.GetNonconformitiesAsync();
        complaintList = await QualityService.GetComplaintsAsync();
    }

    private void SetTab(string tab) { activeTab = tab; }

    // ── Filtered lists ──
    private IEnumerable<NCListDto> FilteredNC =>
        ncList.Where(nc =>
            (string.IsNullOrWhiteSpace(ncSearchTerm) || nc.Title.Contains(ncSearchTerm, StringComparison.OrdinalIgnoreCase) || (nc.Origin ?? "").Contains(ncSearchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(ncStatusFilter) || nc.Status.ToString() == ncStatusFilter) &&
            (string.IsNullOrWhiteSpace(ncSeverityFilter) || nc.Severity.ToString() == ncSeverityFilter)
        );

    private IEnumerable<ComplaintListDto> FilteredComplaints =>
        complaintList.Where(c =>
            string.IsNullOrWhiteSpace(complaintSearchTerm) ||
            c.Source.Contains(complaintSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            c.Description.Contains(complaintSearchTerm, StringComparison.OrdinalIgnoreCase)
        );

    // ── NC CRUD ──
    private async Task SelectNC(Guid id)
    {
        selectedNC = await QualityService.GetNCByIdAsync(id);
    }
    private void CloseNCDetail() { selectedNC = null; }

    private void OpenCreateNCModal()
    {
        isEditingNC = false;
        editingNCId = null;
        ncModel = new NCFormModel();
        ncErrorMessage = null;
        showNCModal = true;
    }

    private void OpenEditNCModal(NCListDto nc)
    {
        isEditingNC = true;
        editingNCId = nc.Id;
        ncModel = new NCFormModel
        {
            Title = nc.Title,
            Description = "",
            Severity = nc.Severity.ToString(),
            Origin = nc.Origin ?? "",
            ImpactPatient = nc.ImpactPatient,
            RootCauseAnalysis = nc.RootCauseAnalysis ?? ""
        };
        ncErrorMessage = null;
        showNCModal = true;
    }

    private async Task SaveNC()
    {
        if (string.IsNullOrWhiteSpace(ncModel.Title)) { ncErrorMessage = "El título es obligatorio."; return; }

        Enum.TryParse<NCSeverity>(ncModel.Severity, out var sev);
        var req = new CreateNCRequest(
            ncModel.Title, ncModel.Description ?? "", sev, null,
            ncModel.ImpactPatient, ncModel.Containment, ncModel.Origin,
            ncModel.RootCauseAnalysis, currentUserId
        );

        if (isEditingNC && editingNCId.HasValue)
            await QualityService.UpdateNCAsync(editingNCId.Value, req);
        else
            await QualityService.CreateNCAsync(req);

        showNCModal = false;
        await LoadData();
    }

    private async Task ChangeNCStatus(NCStatus status)
    {
        if (selectedNC == null) return;
        await QualityService.UpdateNCStatusAsync(selectedNC.Id, status, currentUserId);
        selectedNC = await QualityService.GetNCByIdAsync(selectedNC.Id);
        await LoadData();
    }

    private void ConfirmDeleteNC(NCListDto nc)
    {
        deleteConfirmMessage = $"¿Está seguro de eliminar la NC '{nc.Title}'? Esta acción es irreversible.";
        deleteAction = async () =>
        {
            await QualityService.DeleteNCAsync(nc.Id);
            if (selectedNC?.Id == nc.Id) selectedNC = null;
            await LoadData();
        };
        showDeleteConfirm = true;
    }

    // ── CAPA CRUD ──
    private void OpenCreateCAPAModal()
    {
        capaModel = new CAPAFormModel();
        showCAPAModal = true;
    }

    private async Task SaveCAPA()
    {
        if (selectedNC == null || string.IsNullOrWhiteSpace(capaModel.Description)) return;

        Enum.TryParse<CAPAActionType>(capaModel.ActionType, out var at);
        var req = new CreateCAPARequest(
            selectedNC.Id, at, capaModel.Description,
            currentUserId, capaModel.DueDate
        );
        await QualityService.CreateCAPAAsync(req);
        showCAPAModal = false;
        selectedNC = await QualityService.GetNCByIdAsync(selectedNC.Id);
        await LoadData();
    }

    private async Task CompleteCAPAAction(Guid capaId)
    {
        await QualityService.CompleteCAPAAsync(capaId, null, currentUserId);
        if (selectedNC != null) selectedNC = await QualityService.GetNCByIdAsync(selectedNC.Id);
        await LoadData();
    }

    private async Task DeleteCAPAAction(Guid capaId)
    {
        await QualityService.DeleteCAPAAsync(capaId);
        if (selectedNC != null) selectedNC = await QualityService.GetNCByIdAsync(selectedNC.Id);
        await LoadData();
    }

    // ── Complaint CRUD ──
    private async Task SelectComplaint(Guid id)
    {
        selectedComplaint = await QualityService.GetComplaintByIdAsync(id);
    }
    private void CloseComplaintDetail() { selectedComplaint = null; }

    private void OpenCreateComplaintModal()
    {
        isEditingComplaint = false;
        editingComplaintId = null;
        complaintModel = new ComplaintFormModel();
        showComplaintModal = true;
    }

    private async Task OpenEditComplaintModal(ComplaintListDto cDto)
    {
        var c = await QualityService.GetComplaintByIdAsync(cDto.Id);
        if (c == null) return;
        isEditingComplaint = true;
        editingComplaintId = c.Id;
        complaintModel = new ComplaintFormModel
        {
            Source = c.Source,
            Description = c.Description,
            Category = c.Category.ToString(),
            InvestigationResult = c.InvestigationResult,
            CorrectiveAction = c.CorrectiveAction
        };
        showComplaintModal = true;
    }

    private async Task EditSelectedComplaint()
    {
        if (selectedComplaint == null) return;
        var cDto = complaintList.FirstOrDefault(x => x.Id == selectedComplaint.Id);
        if (cDto != null)
        {
            await OpenEditComplaintModal(cDto);
            CloseComplaintDetail();
        }
    }

    private async Task SaveComplaint()
    {
        if (string.IsNullOrWhiteSpace(complaintModel.Source) || string.IsNullOrWhiteSpace(complaintModel.Description)) return;
        Enum.TryParse<ComplaintCategory>(complaintModel.Category, out var cat);
        var req = new CreateComplaintRequest(
            complaintModel.Source, complaintModel.Description, cat,
            complaintModel.InvestigationResult, complaintModel.CorrectiveAction
        );
        if (isEditingComplaint && editingComplaintId.HasValue)
        {
            await QualityService.UpdateComplaintAsync(editingComplaintId.Value, req);
        }
        else
        {
            await QualityService.CreateComplaintAsync(req);
        }
        showComplaintModal = false;
        await LoadData();
    }

    private async Task ChangeComplaintStatus(ComplaintStatus status)
    {
        if (selectedComplaint == null) return;
        await QualityService.UpdateComplaintStatusAsync(selectedComplaint.Id, status, currentUserId);
        selectedComplaint = await QualityService.GetComplaintByIdAsync(selectedComplaint.Id);
        await LoadData();
    }

    private void ConfirmDeleteComplaint(ComplaintListDto c)
    {
        deleteConfirmMessage = $"¿Está seguro de eliminar la queja de '{c.Source}'? Esta acción es irreversible.";
        deleteAction = async () =>
        {
            await QualityService.DeleteComplaintAsync(c.Id);
            if (selectedComplaint?.Id == c.Id) selectedComplaint = null;
            await LoadData();
        };
        showDeleteConfirm = true;
    }

    private async Task ExecuteDelete()
    {
        if (deleteAction != null) await deleteAction();
        showDeleteConfirm = false;
        deleteAction = null;
    }

    // ── Label Helpers ──
    private string GetSeverityLabel(NCSeverity s) => s switch { NCSeverity.LOW => "Baja", NCSeverity.MEDIUM => "Media", NCSeverity.HIGH => "Alta", NCSeverity.CRITICAL => "Crítica", _ => s.ToString() };
    private string GetSeverityBadgeClass(NCSeverity s) => s switch { NCSeverity.LOW => "bg-secondary-subtle text-secondary", NCSeverity.MEDIUM => "bg-warning-subtle text-warning", NCSeverity.HIGH => "bg-danger-subtle text-danger", NCSeverity.CRITICAL => "bg-danger text-white", _ => "bg-light text-dark" };
    private string GetStatusLabel(NCStatus s) => s switch { NCStatus.OPEN => "Abierta", NCStatus.INVESTIGATING => "Investigando", NCStatus.ACTION => "En Acción", NCStatus.CLOSED => "Cerrada", _ => s.ToString() };
    private string GetStatusBadgeClass(NCStatus s) => s switch { NCStatus.OPEN => "bg-danger-subtle text-danger", NCStatus.INVESTIGATING => "bg-primary-subtle text-primary", NCStatus.ACTION => "bg-warning-subtle text-warning", NCStatus.CLOSED => "bg-success-subtle text-success", _ => "bg-light" };
    private string GetCAPAStatusLabel(CAPAStatus s) => s switch { CAPAStatus.OPEN => "Pendiente", CAPAStatus.DONE => "Completada", CAPAStatus.VERIFIED => "Verificada", CAPAStatus.CANCELLED => "Cancelada", _ => s.ToString() };
    private string GetCAPAStatusBadge(CAPAStatus s) => s switch { CAPAStatus.OPEN => "bg-warning-subtle text-warning", CAPAStatus.DONE => "bg-success-subtle text-success", CAPAStatus.VERIFIED => "bg-primary-subtle text-primary", CAPAStatus.CANCELLED => "bg-secondary-subtle text-secondary", _ => "bg-light" };
    private string GetComplaintCategoryLabel(ComplaintCategory c) => c switch { ComplaintCategory.PATIENT => "Paciente", ComplaintCategory.CLINICAL => "Clínica", ComplaintCategory.TURNAROUND => "Tiempo Respuesta", ComplaintCategory.REPORT_ERROR => "Error Informe", ComplaintCategory.OTHER => "Otra", _ => c.ToString() };
    private string GetComplaintStatusLabel(ComplaintStatus s) => s switch { ComplaintStatus.OPEN => "Abierta", ComplaintStatus.VALIDATED => "Validada", ComplaintStatus.INVESTIGATING => "Investigando", ComplaintStatus.RESOLVED => "Resuelta", ComplaintStatus.CLOSED => "Cerrada", _ => s.ToString() };
    private string GetComplaintStatusBadge(ComplaintStatus s) => s switch { ComplaintStatus.OPEN => "bg-danger-subtle text-danger", ComplaintStatus.VALIDATED => "bg-info-subtle text-info", ComplaintStatus.INVESTIGATING => "bg-primary-subtle text-primary", ComplaintStatus.RESOLVED => "bg-warning-subtle text-warning", ComplaintStatus.CLOSED => "bg-success-subtle text-success", _ => "bg-light" };
    private string GetClaimantLabel(ClaimantType t) => t switch { ClaimantType.PATIENT => "Paciente", ClaimantType.CLINICIAN => "Clínico", ClaimantType.STAFF => "Personal", ClaimantType.REGULATORY => "Regulatorio", ClaimantType.OTHER => "Otro", _ => t.ToString() };

