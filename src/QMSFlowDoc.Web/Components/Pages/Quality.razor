@page "/quality"
@rendermode InteractiveServer
@using QMSFlowDoc.Application.Services.Quality
@using QMSFlowDoc.Shared.Models
@using QMSFlowDoc.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@using QMSFlowDoc.Application.Services.Identity
@using NCStatus = QMSFlowDoc.Shared.Models.NCStatus
@using ComplaintStatus = QMSFlowDoc.Shared.Models.ComplaintStatus
@using NCSeverity = QMSFlowDoc.Shared.Models.NCSeverity
@using CAPAStatus = QMSFlowDoc.Shared.Models.CAPAStatus
@using ComplaintCategory = QMSFlowDoc.Shared.Models.ComplaintCategory
@using ClaimantType = QMSFlowDoc.Shared.Models.ClaimantType
@using Nonconformity = QMSFlowDoc.Shared.Models.Nonconformity
@using Complaint = QMSFlowDoc.Shared.Models.Complaint
@using CAPAActionType = QMSFlowDoc.Shared.Models.CAPAActionType
@using ClinicalImpact = QMSFlowDoc.Shared.Models.ClinicalImpact
@attribute [Authorize]
@inject IQualityService QualityService
@inject IJSRuntime JS
@inject IPermissionService PermissionService


<PageTitle>No Conformidades y Calidad — QMSFlowDoc</PageTitle>

@if (!canRead)
{
    <div class="quality-container py-4">
        <div class="alert alert-danger p-4 rounded-4 shadow-sm border border-danger border-opacity-25 mt-4 text-center">
            <i class="bi bi-shield-slash-fill fs-1 text-danger d-block mb-3"></i>
            <h4 class="fw-bold">Acceso No Autorizado</h4>
            <p class="text-muted mb-0">Su rol de usuario no tiene permisos de lectura para acceder a No Conformidades.</p>
        </div>
    </div>
}
else
{
    <div class="quality-container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1"><i class="bi bi-shield-exclamation text-danger me-2"></i>No Conformidades y Calidad</h1>
            <p class="text-muted mb-0">Gestión de no conformidades, acciones CAPA y quejas/reclamaciones (ISO 15189 §8.7)</p>
        </div>
        <div class="d-flex gap-2">
            @if (canCreate)
            {
                <button class="btn btn-premium px-4" @onclick="OpenCreateNCModal">
                    <i class="bi bi-plus-circle-fill me-2"></i> Registrar NC
                </button>
            }
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">NC Abiertas</span>
                        <h3 class="fw-bold mb-0 text-danger">@ncList.Count(nc => nc.Status == NCStatus.OPEN || nc.Status == NCStatus.INVESTIGATING || nc.Status == NCStatus.ACTION)</h3>
                    </div>
                    <div class="stat-icon-quality bg-danger-soft rounded-3 p-2"><i class="bi bi-exclamation-triangle-fill text-danger h4 mb-0"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">NC Cerradas</span>
                        <h3 class="fw-bold mb-0 text-success">@ncList.Count(nc => nc.Status == NCStatus.CLOSED)</h3>
                    </div>
                    <div class="stat-icon-quality bg-success-soft rounded-3 p-2"><i class="bi bi-check-circle-fill text-success h4 mb-0"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Impacto Paciente</span>
                        <h3 class="fw-bold mb-0 text-warning">@ncList.Count(nc => nc.ImpactPatient)</h3>
                    </div>
                    <div class="stat-icon-quality bg-warning-soft rounded-3 p-2"><i class="bi bi-person-exclamation text-warning h4 mb-0"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-4 border-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small d-block">Quejas Activas</span>
                        <h3 class="fw-bold mb-0 text-info">@complaintList.Count(c => c.Status != ComplaintStatus.CLOSED)</h3>
                    </div>
                    <div class="stat-icon-quality bg-info-soft rounded-3 p-2"><i class="bi bi-chat-left-text-fill text-info h4 mb-0"></i></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-pills mb-4 gap-2">
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 @(activeTab == "nc" ? "active bg-dark text-white" : "bg-light text-dark border")" @onclick='() => SetTab("nc")'>
                <i class="bi bi-exclamation-octagon me-1"></i> No Conformidades <span class="badge bg-danger ms-1 rounded-pill">@ncList.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill px-4 @(activeTab == "complaints" ? "active bg-dark text-white" : "bg-light text-dark border")" @onclick='() => SetTab("complaints")'>
                <i class="bi bi-chat-left-dots me-1"></i> Quejas y Reclamaciones <span class="badge bg-info ms-1 rounded-pill">@complaintList.Count</span>
            </button>
        </li>
    </ul>

    <!-- NC Tab -->
    @if (activeTab == "nc")
    {
        <!-- Search & Filters -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-3">
                <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar por título, origen..." @bind="ncSearchTerm" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" @bind="ncStatusFilter">
                            <option value="">Todos los estados</option>
                            <option value="OPEN">Abierta</option>
                            <option value="INVESTIGATING">Investigando</option>
                            <option value="ACTION">En Acción</option>
                            <option value="CLOSED">Cerrada</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="ncSeverityFilter">
                            <option value="">Toda severidad</option>
                            <option value="CRITICAL">Crítica</option>
                            <option value="HIGH">Alta</option>
                            <option value="MEDIUM">Media</option>
                            <option value="LOW">Baja</option>
                        </select>
                    </div>
                    <div class="col-md-2 text-end">
                        <span class="text-muted small">@FilteredNC.Count() resultados</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- NC Grid -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Título</th>
                            <th>Severidad</th>
                            <th>Estado</th>
                            <th>Origen</th>
                            <th>Paciente</th>
                            <th>Acciones</th>
                            <th>Fecha</th>
                            <th class="text-end pe-4">Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredNC.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted opacity-50"></i>
                                    No se encontraron no conformidades.
                                </td>
                            </tr>
                        }
                        @foreach (var nc in FilteredNC)
                        {
                            <tr class="cursor-pointer" @onclick="() => SelectNC(nc.Id)">
                                <td class="ps-4">
                                    <div class="fw-semibold text-dark">@nc.Title</div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @GetSeverityBadgeClass(nc.Severity)">
                                        @GetSeverityLabel(nc.Severity)
                                    </span>
                                </td>
                                <td>
                                    <span class="badge rounded-pill @GetStatusBadgeClass(nc.Status)">
                                        @GetStatusLabel(nc.Status)
                                    </span>
                                </td>
                                <td class="text-muted small">@(nc.Origin ?? "—")</td>
                                <td>
                                    @if (nc.ImpactPatient)
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill"><i class="bi bi-exclamation-diamond-fill me-1"></i>Sí</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                        <i class="bi bi-clipboard-check me-1"></i>@nc.ActionCount
                                    </span>
                                </td>
                                <td class="text-muted small">@nc.DetectedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-outline-secondary btn-sm rounded-3 px-3 me-1" @onclick="() => SelectNC(nc.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-light btn-sm rounded-3 border px-2" @onclick="() => OpenEditNCModal(nc)" @onclick:stopPropagation="true">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    @if (canDelete)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-3 px-2 ms-1" @onclick="() => ConfirmDeleteNC(nc)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Complaints Tab -->
    @if (activeTab == "complaints")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="input-group" style="max-width: 400px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar quejas..." @bind="complaintSearchTerm" @bind:event="oninput" />
            </div>
            @if (canCreate)
            {
                <button class="btn btn-premium px-4" @onclick="OpenCreateComplaintModal">
                    <i class="bi bi-plus-circle-fill me-2"></i> Registrar Queja
                </button>
            }
        </div>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Fuente</th>
                            <th>Categoría</th>
                            <th>Estado</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th class="text-end pe-4">Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!FilteredComplaints.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-muted opacity-50"></i>
                                    No se encontraron quejas ni reclamaciones.
                                </td>
                            </tr>
                        }
                        @foreach (var c in FilteredComplaints)
                        {
                            <tr class="cursor-pointer" @onclick="() => SelectComplaint(c.Id)">
                                <td class="ps-4 fw-semibold">@c.Source</td>
                                <td><span class="badge rounded-pill bg-info-subtle text-info">@GetComplaintCategoryLabel(c.Category)</span></td>
                                <td><span class="badge rounded-pill @GetComplaintStatusBadge(c.Status)">@GetComplaintStatusLabel(c.Status)</span></td>
                                <td class="text-muted small text-truncate" style="max-width: 300px;">@c.Description</td>
                                <td class="text-muted small">@c.Date.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-outline-secondary btn-sm rounded-3 px-3 me-1" @onclick="() => SelectComplaint(c.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @if (canEdit)
                                    {
                                        <button class="btn btn-light btn-sm rounded-3 border px-2 me-1" @onclick="() => OpenEditComplaintModal(c)" @onclick:stopPropagation="true">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }
                                    @if (canDelete)
                                    {
                                        <button class="btn btn-outline-danger btn-sm rounded-3 px-2 ms-1" @onclick="() => ConfirmDeleteComplaint(c)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    </div>
}

<!-- ============ NC Detail Drawer ============ -->
@if (selectedNC != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);" @onclick="CloseNCDetail">
        <div class="modal-dialog modal-lg modal-dialog-scrollable" @onclick:stopPropagation="true">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header bg-gradient-dark text-white rounded-top-4 py-3 px-4" style="background: linear-gradient(135deg, #1e293b 0%, #334155 100%);">
                    <div>
                        <h5 class="modal-title fw-bold mb-0"><i class="bi bi-exclamation-octagon me-2"></i>@selectedNC.Title</h5>
                        <small class="opacity-75">Detectada el @selectedNC.DetectedAt.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseNCDetail"></button>
                </div>
                <div class="modal-body p-4">
                    <!-- Status & Severity Badges -->
                    <div class="d-flex gap-2 mb-4">
                        <span class="badge rounded-pill px-3 py-2 @GetSeverityBadgeClass(selectedNC.Severity) fs-7">
                            <i class="bi bi-speedometer2 me-1"></i>@GetSeverityLabel(selectedNC.Severity)
                        </span>
                        <span class="badge rounded-pill px-3 py-2 @GetStatusBadgeClass(selectedNC.Status) fs-7">
                            <i class="bi bi-flag me-1"></i>@GetStatusLabel(selectedNC.Status)
                        </span>
                        @if (selectedNC.Status == NCStatus.CLOSED)
                        {
                            <span class="badge rounded-pill px-3 py-2 bg-success text-white fs-7">
                                <i class="bi bi-person-check-fill me-1"></i>Cerrada por: @(selectedNC.ClosedByUserName ?? "Sistema") @(selectedNC.ClosedAt.HasValue ? $"el {selectedNC.ClosedAt.Value.ToString("dd/MM/yyyy HH:mm")}" : "")
                            </span>
                        }
                        @if (selectedNC.ImpactPatient)
                        {
                            <span class="badge rounded-pill px-3 py-2 bg-danger text-white fs-7">
                                <i class="bi bi-heart-pulse me-1"></i>Impacto Paciente
                            </span>
                        }
                    </div>

                    <!-- Description Section -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-card-text me-2"></i>Descripción</h6>
                        <p class="bg-light rounded-3 p-3 mb-0">@selectedNC.Description</p>
                    </div>

                    <!-- Details Grid -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="bg-light rounded-3 p-3">
                                <small class="text-muted d-block mb-1">Origen</small>
                                <span class="fw-semibold">@(selectedNC.Origin ?? "No especificado")</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded-3 p-3">
                                <small class="text-muted d-block mb-1">Contención Inmediata</small>
                                <span class="fw-semibold">@(selectedNC.Containment ?? "No especificada")</span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selectedNC.RootCauseAnalysis))
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-diagram-3 me-2"></i>Análisis de Causa Raíz</h6>
                            <p class="bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-3 p-3 mb-0">@selectedNC.RootCauseAnalysis</p>
                        </div>
                    }

                    <!-- Status Change -->
                    @if (canEdit && selectedNC.Status != NCStatus.CLOSED)
                    {
                        <div class="mb-4 p-3 border rounded-3 bg-light">
                            <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-arrow-right-circle me-2"></i>Cambiar Estado</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                @if (selectedNC.Status == NCStatus.OPEN)
                                {
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => ChangeNCStatus(NCStatus.INVESTIGATING)">
                                        <i class="bi bi-search me-1"></i>Investigar
                                    </button>
                                }
                                @if (selectedNC.Status == NCStatus.OPEN || selectedNC.Status == NCStatus.INVESTIGATING)
                                {
                                    <button class="btn btn-sm btn-outline-warning rounded-pill px-3" @onclick="() => ChangeNCStatus(NCStatus.ACTION)">
                                        <i class="bi bi-gear me-1"></i>En Acción
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-success rounded-pill px-3" @onclick="() => ChangeNCStatus(NCStatus.CLOSED)">
                                    <i class="bi bi-check-lg me-1"></i>Cerrar NC
                                </button>
                            </div>
                        </div>
                    }

                    <!-- CAPA Actions Section -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold text-secondary mb-0"><i class="bi bi-clipboard-check me-2"></i>Acciones CAPA (@selectedNC.Actions.Count)</h6>
                            @if (canCreate)
                            {
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="OpenCreateCAPAModal">
                                    <i class="bi bi-plus-lg me-1"></i>Nueva CAPA
                                </button>
                            }
                        </div>

                        @if (!selectedNC.Actions.Any())
                        {
                            <div class="text-center py-3 text-muted bg-light rounded-3">
                                <i class="bi bi-clipboard2 d-block mb-1 fs-4 opacity-50"></i>
                                <small>No hay acciones CAPA registradas.</small>
                            </div>
                        }
                        else
                        {
                            @foreach (var capa in selectedNC.Actions.OrderBy(a => a.Status).ThenBy(a => a.DueDate))
                            {
                                <div class="border rounded-3 p-3 mb-2 bg-white shadow-sm">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="badge rounded-pill me-2 @(capa.ActionType == CAPAActionType.CORRECTIVE ? "bg-primary" : "bg-info text-dark")">
                                                @(capa.ActionType == CAPAActionType.CORRECTIVE ? "Correctiva" : "Preventiva")
                                            </span>
                                            <span class="badge rounded-pill @GetCAPAStatusBadge(capa.Status)">@GetCAPAStatusLabel(capa.Status)</span>
                                        </div>
                                        <div class="d-flex gap-1">
                                            @if (canEdit && capa.Status == CAPAStatus.OPEN)
                                            {
                                                <button class="btn btn-sm btn-outline-success rounded-pill px-2" title="Completar" @onclick="() => CompleteCAPAAction(capa.Id)">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            }
                                            @if (canDelete)
                                            {
                                                <button class="btn btn-sm btn-outline-danger rounded-pill px-2" title="Eliminar" @onclick="() => DeleteCAPAAction(capa.Id)">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    <p class="mb-1 mt-2 small">@capa.Description</p>
                                    <div class="d-flex gap-3 text-muted small">
                                        @if (capa.DueDate.HasValue)
                                        {
                                            <span><i class="bi bi-calendar3 me-1"></i>Vence: @capa.DueDate.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                        @if (capa.CompletedAt.HasValue)
                                        {
                                            <span class="text-success"><i class="bi bi-check2-circle me-1"></i>Completada: @capa.CompletedAt.Value.ToString("dd/MM/yyyy") por @(capa.ClosedByUserName ?? "Sistema")</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(capa.EffectivenessCheck))
                                    {
                                        <div class="mt-2 p-2 bg-success bg-opacity-10 rounded-2 small text-success">
                                            <i class="bi bi-patch-check me-1"></i>Eficacia: @capa.EffectivenessCheck
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ============ Complaint Detail Drawer ============ -->
@if (selectedComplaint != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);" @onclick="CloseComplaintDetail">
        <div class="modal-dialog modal-lg modal-dialog-scrollable" @onclick:stopPropagation="true">
            <div class="modal-content rounded-4 border-0 shadow-lg">
                <div class="modal-header bg-gradient-dark text-white rounded-top-4 py-3 px-4" style="background: linear-gradient(135deg, #0c4a6e 0%, #0369a1 100%);">
                    <div>
                        <h5 class="modal-title fw-bold mb-0"><i class="bi bi-chat-left-text me-2"></i>Queja / Reclamación</h5>
                        <small class="opacity-75">Registrada el @selectedComplaint.Date.ToString("dd/MM/yyyy")</small>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseComplaintDetail"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex gap-2 mb-4">
                        <span class="badge rounded-pill px-3 py-2 bg-info-subtle text-info fs-7">@GetComplaintCategoryLabel(selectedComplaint.Category)</span>
                        <span class="badge rounded-pill px-3 py-2 @GetComplaintStatusBadge(selectedComplaint.Status) fs-7">@GetComplaintStatusLabel(selectedComplaint.Status)</span>
                        @if (selectedComplaint.Status == ComplaintStatus.CLOSED)
                        {
                            <span class="badge rounded-pill px-3 py-2 bg-success text-white fs-7">
                                <i class="bi bi-person-check-fill me-1"></i>Cerrada por: @(selectedComplaint.ClosedByUserName ?? "Sistema") @(selectedComplaint.ClosedAt.HasValue ? $"el {selectedComplaint.ClosedAt.Value.ToString("dd/MM/yyyy HH:mm")}" : "")
                            </span>
                        }
                        @if (selectedComplaint.ClinicalImpact != ClinicalImpact.NONE)
                        {
                            <span class="badge rounded-pill px-3 py-2 bg-danger text-white fs-7">
                                <i class="bi bi-heart-pulse me-1"></i>Impacto Clínico: @selectedComplaint.ClinicalImpact
                            </span>
                        }
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="bg-light rounded-3 p-3">
                                <small class="text-muted d-block mb-1">Fuente / Reclamante</small>
                                <span class="fw-semibold">@selectedComplaint.Source</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light rounded-3 p-3">
                                <small class="text-muted d-block mb-1">Tipo de Reclamante</small>
                                <span class="fw-semibold">@GetClaimantLabel(selectedComplaint.ClaimantType)</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-card-text me-2"></i>Descripción</h6>
                        <p class="bg-light rounded-3 p-3 mb-0">@selectedComplaint.Description</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selectedComplaint.InvestigationResult))
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-search me-2"></i>Resultado Investigación</h6>
                            <p class="bg-info bg-opacity-10 rounded-3 p-3 mb-0">@selectedComplaint.InvestigationResult</p>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(selectedComplaint.CorrectiveAction))
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-tools me-2"></i>Acción Correctiva</h6>
                            <p class="bg-success bg-opacity-10 rounded-3 p-3 mb-0">@selectedComplaint.CorrectiveAction</p>
                        </div>
                    }

                    <!-- Status Change for Complaint -->
                    @if (canEdit && selectedComplaint.Status != ComplaintStatus.CLOSED)
                    {
                        <div class="p-3 border rounded-3 bg-light">
                            <h6 class="fw-bold text-secondary mb-2"><i class="bi bi-arrow-right-circle me-2"></i>Acciones y Cambiar Estado</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                @if (selectedComplaint.Status == ComplaintStatus.OPEN)
                                {
                                    <button class="btn btn-sm btn-outline-info rounded-pill px-3" @onclick="() => ChangeComplaintStatus(ComplaintStatus.VALIDATED)">Validar</button>
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => ChangeComplaintStatus(ComplaintStatus.INVESTIGATING)">Investigar</button>
                                }
                                @if (selectedComplaint.Status == ComplaintStatus.VALIDATED || selectedComplaint.Status == ComplaintStatus.INVESTIGATING)
                                {
                                    <button class="btn btn-sm btn-outline-warning rounded-pill px-3" @onclick="() => ChangeComplaintStatus(ComplaintStatus.RESOLVED)">Resolver</button>
                                }
                                <button class="btn btn-sm btn-outline-success rounded-pill px-3" @onclick="() => ChangeComplaintStatus(ComplaintStatus.CLOSED)">
                                    <i class="bi bi-check-lg me-1"></i>Cerrar
                                </button>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" @onclick="() => EditSelectedComplaint()">
                                    <i class="bi bi-pencil me-1"></i>Editar Queja
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

